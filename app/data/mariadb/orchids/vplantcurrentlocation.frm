S `isActive`,`lochistory`.`updatedDateTime`\nAS `updatedDateTime`,row_number() over ( partition by `lochistory`.`plantId` order by `lochistory`.`startDateTime` desc)\nAS `RowOrder` FROM `plantlocationhistory` `lochistory` WHERE `lochistory`.`isActive` = 1) `sub` WHERE `sub`.`RowOrder` = 1) `plh` on(`plant`.`plantId` = `plh`.`plantId`)) left join `location` `loc` on(`loc`.`locationId` = `plh`.`locationId` and `loc`.`isActive` = 1)) WHERE `plant`.`isActive` = 1
