Date` FROM `repotting` `r` WHERE `r`.`isActive` = 1 group by `r`.`plantId`) `repot` on(`repot`.`plantId` = `p`.`plantId`)) left join `plantlocationhistory` `plh` on(`plh`.`plantId` = `p`.`plantId` and `plh`.`isActive` = 1 and `plh`.`endDateTime` is null)) left join `location` `l` on(`l`.`locationId` = `plh`.`locationId`)) WHERE `p`.`endDate` is null) `base`
