@page
@model OrchidApp.Web.Pages.Setup.IndexModel

<h1 class="page-title fw-bold">Setup</h1>

<p class="text-muted">
Before adding plants, define the plant groups (such as Phalaenopsis or Cattleya) 
and the locations where you keep them.
</p>

<div class="d-grid gap-3 mt-4">

    <a asp-page="/Setup/Genera/Index"
       asp-route-returnUrl="@(Request.Path + Request.QueryString)"
       class="btn btn-lg btn-outline-primary">
        Plant groups (Genera)
    </a>

    <a asp-page="/Setup/Taxa/Index"
       class="btn btn-lg btn-outline-primary">
        Plant varieties (species & hybrids)
    </a>

    <a asp-page="/Setup/Locations/Index"
       class="btn btn-lg btn-outline-primary disabled"
       tabindex="-1"
       aria-disabled="true">
        Growing locations (coming soon)
    </a>

</div>

<div class="mt-4">
    <a asp-page="/Index"
       class="btn btn-outline-secondary btn-lg w-100">
        ← Back to home
    </a>
</div>