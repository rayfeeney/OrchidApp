@page
@model OrchidApp.Web.Pages.Setup.IndexModel

<h1 class="page-title fw-bold">Setup</h1>

<h2 class="h5 fw-bold mb-3">
Define the plant groups (Genera), species / hybrids and locations
</h2>

<p class="text-muted">
Before adding plants, you should define the plant groups 
(<strong>genera</strong>, singular: genus) and the 
<strong>species or hybrids</strong> (varieties) in your collection, 
as well as the locations where you keep them.
</p>

<div class="d-grid gap-3 mt-4">

    <a asp-page="/Setup/Genera/Index"
       asp-route-returnUrl="@(Request.Path + Request.QueryString)"
       class="btn btn-lg btn-outline-primary">
        Plant groups (Genera)
    </a>

    <a asp-page="/Setup/Taxa/Index"
       class="btn btn-lg btn-outline-primary">
        Species / Hybrids (varieties)
    </a>

    <a asp-page="/Setup/Locations/Index"
       class="btn btn-lg btn-outline-primary">
        Growing locations (Greenhouse, garden, etc.)
    </a>

    <a asp-page="/Setup/GrowthMedia/Index"
       class="btn btn-lg btn-outline-primary">
        Growth media (soil, bark, etc.)
    </a>
</div>

<div class="mt-4">
    <a asp-page="/Index"
       class="btn btn-outline-secondary btn-lg w-100">
        ← Back to home
    </a>
</div>