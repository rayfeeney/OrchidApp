@page "{growthMediumId:int}"
@model OrchidApp.Web.Pages.Setup.GrowthMedia.DetailsModel

@{
    var isInactive = !Model.GrowthMedium!.IsActive;
}

<h1 class="page-title fw-bold d-flex align-items-center gap-2 @(isInactive ? "text-muted" : "")">
    @Model.GrowthMedium.Name

    @if (isInactive)
    {
        <span class="badge bg-secondary">
            Inactive
        </span>
    }
</h1>

<h2 class="h5 fw-bold mb-3">
    Growth medium details
</h2>
 
<div class="card mt-3">
    <div class="card-body">

        <dl class="row mb-0">

            <dt class="col-sm-3 fw-bold">Name</dt>
            <dd class="col-sm-9">
                @Model.GrowthMedium.Name
            </dd>

            <dt class="col-sm-3 fw-bold">Description</dt>
            <dd class="col-sm-9">
                @(string.IsNullOrWhiteSpace(Model.GrowthMedium.Description)
                    ? "—"
                    : Model.GrowthMedium.Description)
            </dd>

        </dl>

    </div>
</div>

<div class="d-grid gap-2 mt-4">

    <a asp-page="/Setup/GrowthMedia/Actions/Edit"
    asp-route-growthMediumId="@Model.GrowthMedium.GrowthMediumId"
    asp-route-returnUrl="@(Model.ReturnUrl ?? Url.Page("/Setup/GrowthMedia/Index"))"
    class="btn btn-lg btn-primary">
        Edit growth medium
    </a>

    <form method="post"
        asp-route-growthMediumId="@Model.GrowthMedium.GrowthMediumId"
        class="d-grid">

        <button type="submit"
                asp-page-handler="ToggleActive"
                class="btn btn-lg @(Model.GrowthMedium.IsActive ? "btn-outline-danger" : "btn-outline-success")"
                onclick="return confirm('Are you sure you want to @(Model.GrowthMedium.IsActive ? "deactivate" : "reactivate") this growth medium?');">

            @(Model.GrowthMedium.IsActive ? "Deactivate growth medium" : "Reactivate growth medium")

        </button>

    </form>

    <partial name="_BackFullWidth"
            model='@Url.Page("/Setup/GrowthMedia/Index")' />
</div>