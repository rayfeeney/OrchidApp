@page "{id:int}"
@model OrchidApp.Web.Pages.Setup.Taxa.DetailsModel

@{
    var isInactive = !Model.Taxon!.GenusIsActive || !Model.Taxon.TaxonIsActive;
}

<h1 class="page-title fw-bold d-flex align-items-center gap-2 @(isInactive ? "text-muted" : "")">
    @Model.Taxon!.DisplayName

    @if (isInactive)
    {
        <span class="badge bg-secondary">
            Inactive
        </span>
    }
</h1>

<h2 class="h5 fw-bold mb-3">
Species / hybrid details
</h2>

<div class="card mt-3">
    <div class="card-body">

        <dl class="row mb-0">

            <dt class="col-sm-3 fw-bold">
                @Html.DisplayNameFor(m => m.Taxon!.GenusName)
            </dt>
            <dd class="col-sm-9">@Model.Taxon.GenusName</dd>

            @if (!string.IsNullOrWhiteSpace(Model.Taxon.SpeciesName))
            {
                <dt class="col-sm-3 fw-bold">
                    @Html.DisplayNameFor(m => m.Taxon!.SpeciesName)
                </dt>
                <dd class="col-sm-9">@Model.Taxon.SpeciesName</dd>
            }

            @if (!string.IsNullOrWhiteSpace(Model.Taxon.HybridName))
            {
                <dt class="col-sm-3 fw-bold">
                    @Html.DisplayNameFor(m => m.Taxon!.HybridName)
                </dt>
                <dd class="col-sm-9">@Model.Taxon.HybridName</dd>
            }

            <dt class="col-sm-3 fw-bold">
                @Html.DisplayNameFor(m => m.Taxon!.GrowthNotes)
            </dt>
            <dd class="col-sm-9">
                @(string.IsNullOrWhiteSpace(Model.Taxon.GrowthNotes) ? "—" : Model.Taxon.GrowthNotes)
            </dd>

            <dt class="col-sm-3 fw-bold">
                @Html.DisplayNameFor(m => m.Taxon!.TaxonNotes)
            </dt>
            <dd class="col-sm-9">
                @(string.IsNullOrWhiteSpace(Model.Taxon.TaxonNotes) ? "—" : Model.Taxon.TaxonNotes)
            </dd>

            @if (!string.IsNullOrWhiteSpace(Model.PhotoFileName))
            {
                <div class="text-center mt-3 mb-3">
                    <img src="~/uploads/taxa/@Model.Taxon.TaxonId/@Model.PhotoFileName"
                        class="img-fluid rounded shadow"
                        style="max-height:40vh;" />
                </div>
            }

        </dl>

    </div>
</div>

@if (Model.Taxon != null)
{
    <div class="d-grid gap-2 mt-4">

        <a asp-page="/Setup/Taxa/Actions/Edit"
           asp-route-id="@Model.Taxon.TaxonId"
           asp-route-returnUrl="@(Request.Path + Request.QueryString)"
           class="btn btn-primary btn-lg">
            Edit species / hybrid
        </a>

        <form method="post" class="d-grid">

            <input type="hidden" name="ReturnUrl" value="@Model.ReturnUrl" />

            @{
                var isSystemManaged = Model.Taxon.IsSystemManaged;
                var genusInactive = !Model.Taxon.GenusIsActive;
                var isActive = Model.Taxon.TaxonIsActive && Model.Taxon.GenusIsActive;

                var buttonClass = isActive ? "btn-outline-danger" : "btn-outline-success";
                var buttonText = isActive ? "Deactivate species / hybrid" : "Reactivate species / hybrid";
                var confirmMessage = isActive
                    ? "Are you sure? This should only be done if the species / hybrid is no longer valid."
                    : "Are you sure? This will reactivate the species / hybrid.";
            }

            @if (isSystemManaged)
            {
                <button type="button"
                        class="btn btn-lg btn-outline-secondary"
                        disabled
                        title="This record is automatically created for the genus and must remain active.">
                    Genus placeholder — managed automatically
                </button>
            }
            else if (genusInactive)
            {
                <button type="button"
                        class="btn btn-lg btn-outline-secondary"
                        disabled
                        title="This species / hybrid cannot be activated or deactivated because its genus is inactive.">
                    Genus inactive — status locked
                </button>
            }
            else
            {
                <button type="submit"
                        asp-page-handler="ToggleActive"
                        class="btn btn-lg @buttonClass"
                        onclick="return confirm('@confirmMessage');">
                    @buttonText
                </button>
            }

</form>

    </div>
}

<partial name="_BackFullWidth"
         model="@(Model.ReturnUrl ?? Url.Page("/Setup/Taxa/Index"))" />