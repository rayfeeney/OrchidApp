@page "{id:int}"
@model OrchidApp.Web.Pages.Setup.Taxa.DetailsModel

<h1 class="page-title fw-bold d-flex align-items-center gap-2">
    @Model.Taxon!.DisplayName

    @if (!Model.Taxon.IsActive)
    {
        <span class="badge bg-secondary">
            Inactive
        </span>
    }
</h1>

<h2 class="h5 fw-bold mb-3">
Species / hybrid details
</h2>

<div class="card mt-3">
    <div class="card-body">

        <dl class="row mb-0">

            <dt class="col-sm-3 fw-bold">
                @Html.DisplayNameFor(m => m.Taxon!.GenusName)
            </dt>
            <dd class="col-sm-9">@Model.Taxon.GenusName</dd>

            @if (!string.IsNullOrWhiteSpace(Model.Taxon.SpeciesName))
            {
                <dt class="col-sm-3 fw-bold">
                    @Html.DisplayNameFor(m => m.Taxon!.SpeciesName)
                </dt>
                <dd class="col-sm-9">@Model.Taxon.SpeciesName</dd>
            }

            @if (!string.IsNullOrWhiteSpace(Model.Taxon.HybridName))
            {
                <dt class="col-sm-3 fw-bold">
                    @Html.DisplayNameFor(m => m.Taxon!.HybridName)
                </dt>
                <dd class="col-sm-9">@Model.Taxon.HybridName</dd>
            }

            <dt class="col-sm-3 fw-bold">
                @Html.DisplayNameFor(m => m.Taxon!.GrowthNotes)
            </dt>
            <dd class="col-sm-9">
                @(string.IsNullOrWhiteSpace(Model.Taxon.GrowthNotes) ? "—" : Model.Taxon.GrowthNotes)
            </dd>

            <dt class="col-sm-3 fw-bold">
                @Html.DisplayNameFor(m => m.Taxon!.TaxonNotes)
            </dt>
            <dd class="col-sm-9">
                @(string.IsNullOrWhiteSpace(Model.Taxon.TaxonNotes) ? "—" : Model.Taxon.TaxonNotes)
            </dd>

        </dl>

    </div>
</div>

@if (Model.Taxon != null)
{
    <div class="d-grid gap-2 mt-4">

        <a asp-page="/Setup/Taxa/Actions/Edit"
           asp-route-id="@Model.Taxon.TaxonId"
           asp-route-returnUrl="@(Request.Path + Request.QueryString)"
           class="btn btn-primary btn-lg">
            Edit species / hybrid
        </a>

        <a asp-page="/Setup/Taxa/Actions/Remove"
           asp-route-id="@Model.Taxon.TaxonId"
           asp-route-returnUrl="@(Request.Path + Request.QueryString)"
           class="btn btn-outline-danger btn-lg">
            Deactivate species / hybrid
        </a>

    </div>
}

<partial name="_BackFullWidth"
         model="@(Model.ReturnUrl ?? Url.Page("/Setup/Taxa/Index"))" />