@page
@model OrchidApp.Web.Pages.Setup.Taxa.IndexModel

<h1 class="page-title fw-bold">Species / Hybrids</h1>

<h2 class="h5 fw-bold mb-3">
Botanical names within each genus
</h2>

<p class="text-muted">
Each genus contains one or more species or registered hybrids.
These define the full botanical name of your plants.
</p>

<div class="d-grid gap-2 mb-4">
    <a asp-page="/Setup/Taxa/Actions/Add"
       asp-route-returnUrl="@(Request.Path + Request.QueryString)"
       class="btn btn-lg btn-primary">
        Add species / hybrid
    </a>
</div>

@if (!Model.Taxa.Any())
{
    <p class="text-muted">
        No species or hybrids have been added yet.
    </p>
}
else
{
    <p class="text-muted small mb-2">
        Select a species / hybrid to view or edit its details.
    </p>

    @foreach (var genusGroup in Model.Taxa.GroupBy(t => new { t.GenusName, t.GenusIsActive }))
    {
        var genusInactive = !genusGroup.Key.GenusIsActive;

        <h2 class="h6 fw-bold mt-4 @(genusInactive ? "text-muted" : "")">
            @genusGroup.Key.GenusName

            @if (genusInactive)
            {
                <span class="badge bg-secondary ms-2">Inactive</span>
            }
        </h2>

        <div class="d-grid gap-2">
        @foreach (var taxon in genusGroup)
        {
            var isInactive = !taxon.GenusIsActive || !taxon.TaxonIsActive;

            <a asp-page="/Setup/Taxa/Details"
               asp-route-id="@taxon.TaxonId"
               asp-route-returnUrl="@(Request.Path + Request.QueryString)"
               class="btn btn-lg text-start @(taxon.IsSystemManaged ? "btn-outline-secondary" : "btn-outline-primary") @(isInactive ? "text-muted" : "")">

                <div class="d-flex align-items-center gap-3">

        @if (!string.IsNullOrWhiteSpace(taxon.ThumbnailFileName))
        {
            <img src="~/uploads/taxa/@taxon.TaxonId/@taxon.ThumbnailFileName"
                style="width:64px; height:64px; object-fit:cover;"
                class="rounded border flex-shrink-0" />
        }
        else
        {
            <div style="width:64px; height:64px;"
                class="bg-light border rounded d-flex align-items-center justify-content-center flex-shrink-0">
                —
            </div>
        }

        <div>
            <span>@taxon.DisplayName</span>

        @if (isInactive)
        {
            <span class="badge bg-secondary ms-2">Inactive</span>
        }

        @if (taxon.IsSystemManaged)
        {
            <span class="text-muted small ms-2">
                (genus placeholder)
            </span>
        }
    </div>

</div>

                @if (isInactive)
                {
                    <span class="badge bg-secondary ms-2">Inactive</span>
                }

                @if (taxon.IsSystemManaged)
                {
                    <span class="text-muted small ms-2">
                        (genus placeholder)
                    </span>
                }
            </a>
        }
        </div>
    }
}

<partial name="_BackFullWidth"
         model="@(Model.ReturnUrl ?? Url.Page("/Setup/Index"))" />