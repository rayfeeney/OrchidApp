@page "{id:int}"
@model OrchidApp.Web.Pages.Setup.Taxa.Actions.RemoveModel

<h1 class="page-title fw-bold">Deactivate species / hybrid</h1>

<h2 class="h5 fw-bold mb-3">
Confirm deactivation
</h2>

@if (Model.Taxon != null)
{
    <div class="mt-3">

        <p class="fw-bold">
            @Model.Taxon.DisplayName
        </p>

        <p class="text-muted">
            Deactivating this species or hybrid will remove it from selection lists.
            Existing plants that use this name will remain unchanged.
        </p>

        <p class="text-muted">
            This should normally only be done if the entry was created in error
            or is no longer considered valid.
        </p>

        <form method="post" class="mt-3">

            <partial name="_FormActionsDanger"
                     model="@((Model.ReturnUrl ?? Url.Page("/Setup/Taxa/Details", new { id = Model.Taxon.TaxonId }), "Deactivate species / hybrid"))" />

        </form>
    </div>
}