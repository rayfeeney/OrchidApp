@page "{id:int}"
@model OrchidApp.Web.Pages.Setup.Taxa.Actions.EditModel

<h1 class="page-title fw-bold">Edit species / hybrid</h1>

<h2 class="h5 fw-bold mb-3">
@Model.GenusName
</h2>

<p class="text-muted">
Changing the species or hybrid name will update all plants that use this name.
This should normally only be used for spelling corrections or recognised taxonomic updates.
</p>

<form method="post" class="mt-3">

    <div asp-validation-summary="ModelOnly"
         class="alert alert-danger">
    </div>

    @if (!Model.Taxon.IsSystemManaged)
    {
        @if (!string.IsNullOrWhiteSpace(Model.Taxon.SpeciesName))
        {
            <div class="mb-3">
                <label asp-for="Taxon.SpeciesName" class="fw-bold"></label>
                <small class="text-muted d-block fw-normal">
                    Spelling correction only.
                </small>
                <input asp-for="Taxon.SpeciesName" class="form-control" />
                <span asp-validation-for="Taxon.SpeciesName" class="text-danger"></span>
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(Model.Taxon.HybridName))
        {
            <div class="mb-3">
                <label asp-for="Taxon.HybridName" class="fw-bold"></label>
                <small class="text-muted d-block fw-normal">
                    Spelling correction only.
                </small>
                <input asp-for="Taxon.HybridName" class="form-control" />
                <span asp-validation-for="Taxon.HybridName" class="text-danger"></span>
            </div>
        }
    }

    <div class="mb-3">
        <label asp-for="Taxon.GrowthNotes" class="fw-bold"></label>
        <small class="text-muted d-block fw-normal">
            Optional notes about growth characteristics.
        </small>
        <textarea asp-for="Taxon.GrowthNotes" class="form-control"></textarea>
        <span asp-validation-for="Taxon.GrowthNotes" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Taxon.TaxonNotes" class="fw-bold"></label>
        <small class="text-muted d-block fw-normal">
            Optional notes about this species or hybrid.
        </small>
        <textarea asp-for="Taxon.TaxonNotes" class="form-control"></textarea>
        <span asp-validation-for="Taxon.TaxonNotes" class="text-danger"></span>
    </div>

    <partial name="_FormActions"
             model="@((Model.ReturnUrl ?? Url.Page("/Setup/Taxa/Details", new { id = Model.Taxon.TaxonId }), "Save species / hybrid"))" />

</form>