@page
@model OrchidApp.Web.Pages.Setup.Taxa.Actions.AddModel

<h1>Add species or hybrid</h1>

<form method="post" class="mt-4">

    <div asp-validation-summary="ModelOnly"
        class="alert alert-danger">
    </div>

    <div class="mb-3">
        <label class="form-label">Genus</label>
        <select class="form-select" asp-for="GenusId" required>
            <option value="">Select a genus</option>
            @foreach (var g in Model.Genera)
            {
                <option value="@g.GenusId">@g.GenusName</option>
            }
        </select>
    </div>

    <div class="mb-3">
        <label class="form-label">Species name</label>
        <input class="form-control" asp-for="SpeciesName" />
        <div class="form-text">Leave blank if adding a hybrid</div>
    </div>

    <div class="mb-3">
        <label class="form-label">Hybrid name</label>
        <input class="form-control" asp-for="HybridName" />
        <div class="form-text">Leave blank if adding a species</div>
    </div>

    <div class="mb-3">
        <label class="form-label">Growth notes (optional)</label>
        <textarea class="form-control" asp-for="GrowthNotes"></textarea>
    </div>

    <div class="mb-3">
        <label class="form-label">Species or hybrid notes (optional)</label>
        <textarea class="form-control" asp-for="TaxonNotes"></textarea>
    </div>

    <partial name="_FormActions"
             model="@((Model.ReturnUrl ?? Url.Page("/Setup/Taxa/Index"), "Add species/hybrid"))" />

</form>
