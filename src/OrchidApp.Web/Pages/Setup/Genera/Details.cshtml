@page "{id:int}"
@model OrchidApp.Web.Pages.Setup.Genera.DetailsModel

@{
    var isInactive = !Model.Genus!.IsActive;
}

<h1 class="page-title fw-bold d-flex align-items-center gap-2 @(isInactive ? "text-muted" : "")">
    @Model.Genus!.Name

    @if (!Model.Genus.IsActive)
    {
        <span class="badge bg-secondary">
            Inactive
        </span>
    }
</h1>

<h2 class="h5 fw-bold mb-3">
Genus details
</h2>

<div class="card mt-3">
    <div class="card-body">

        <dl class="row mb-0">

            <dt class="col-sm-3 fw-bold">@Html.DisplayNameFor(m => m.Genus!.Name)</dt>
            <dd class="col-sm-9">@Model.Genus.Name</dd>

            <dt class="col-sm-3 fw-bold">@Html.DisplayNameFor(m => m.Genus!.Notes)</dt>
            <dd class="col-sm-9">
                @(string.IsNullOrWhiteSpace(Model.Genus.Notes) ? "—" : Model.Genus.Notes)
            </dd>

        </dl>

    </div>
</div>

<div class="d-grid gap-2 mt-4">

    <a asp-page="/Setup/Genera/Actions/Edit"
       asp-route-id="@Model.Genus!.GenusId"
       asp-route-returnUrl="@(Request.Path + Request.QueryString)"
       class="btn btn-primary btn-lg">
        Edit genus
    </a>

    <form method="post"
          asp-route-id="@Model.Genus!.GenusId"
          class="d-grid">
        <button type="submit"
                asp-page-handler="ToggleActive"
                class="btn btn-lg @(Model.Genus.IsActive ? "btn-outline-danger" : "btn-outline-success")"
                onclick="return confirm('Are you sure you want to @(Model.Genus.IsActive ? "deactivate" : "reactivate") this genus?');">

            @(Model.Genus.IsActive ? "Deactivate genus" : "Reactivate genus")

        </button>
    </form>
</div>

<partial name="_BackFullWidth"
         model="@(Model.ReturnUrl ?? Url.Page("/Setup/Genera/Index"))" />