@page "{id:int}"
@model OrchidApp.Web.Pages.Setup.Genera.Actions.EditModel

<h1 class="page-title fw-bold">Edit genus</h1>

<h2 class="h5 fw-bold mb-3">
Update the details of this genus
</h2>

<form method="post" class="mt-3">

    <div asp-validation-summary="ModelOnly"
         class="alert alert-danger">
    </div>

    <p class="text-muted">
    Changing the genus name will update all species / hybrids and plants that belong to this genus.
    Use this only for spelling corrections or official taxonomic changes.
    </p>

    <div class="mb-3">
        <label asp-for="Genus.Name" class="fw-bold"></label>
        <small class="text-muted d-block fw-normal">
            Spelling correction only.
        </small>
        <input asp-for="Genus.Name" class="form-control" />
        <span asp-validation-for="Genus.Name"
              class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Genus.Notes" class="fw-bold"></label>
        <small class="text-muted d-block fw-normal">
            Optional notes about this genus.
        </small>
        <textarea asp-for="Genus.Notes"
                  class="form-control"></textarea>
        <span asp-validation-for="Genus.Notes"
              class="text-danger"></span>
    </div>

    <partial name="_FormActions"
             model="@((Model.ReturnUrl ?? Url.Page("/Setup/Genera/Details", new { id = Model.Genus.GenusId }), "Save genus"))" />

</form>