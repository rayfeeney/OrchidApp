@page "{id:int}"
@model OrchidApp.Web.Pages.Setup.Genera.Actions.EditModel

<h1>Edit Genus</h1>

<form method="post" class="mt-3">

    <div class="mb-3">
        <label class="form-label">
            Genus <small class="text-muted">(spelling correction only)</small>
        </label>
        <input asp-for="Genus.Name" class="form-control" />
    </div>

    <div class="mb-3">
        <label class="form-label">Notes</label>
        <textarea asp-for="Genus.Notes" class="form-control"></textarea>
    </div>

    <partial name="_FormActions"
             model="@((Model.ReturnUrl ?? Url.Page("/Setup/Genera/Details", new { id = Model.Genus.GenusId }), "Save"))" />

</form>
