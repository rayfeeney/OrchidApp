@page "{locationId:int}"
@model OrchidApp.Web.Pages.Setup.Locations.DetailsModel

<h1 class="page-title fw-bold">Location details</h1>

@{
    var isInactive = !Model.Location.IsActive;
}

<h2 class="h5 fw-bold mb-3 @(isInactive ? "text-muted" : "")">
    @Model.Location.LocationName

    @if (isInactive)
    {
        <span class="badge bg-secondary ms-2">Inactive</span>
    }
</h2>

<div class="card mt-3">
    <div class="card-body">
        <dl class="row mb-0">

            <dt class="col-sm-3 fw-bold">Location notes</dt>
            <dd class="col-sm-9">
                @(string.IsNullOrWhiteSpace(Model.Location.LocationNotes) ? "—" : Model.Location.LocationNotes)
            </dd>

            <dt class="col-sm-3 fw-bold">Climate notes</dt>
            <dd class="col-sm-9">
                @(string.IsNullOrWhiteSpace(Model.Location.ClimateNotes) ? "—" : Model.Location.ClimateNotes)
            </dd>

            <dt class="col-sm-3 fw-bold">General notes</dt>
            <dd class="col-sm-9">
                @(string.IsNullOrWhiteSpace(Model.Location.LocationGeneralNotes) ? "—" : Model.Location.LocationGeneralNotes)
            </dd>

        </dl>
    </div>
</div>

<div class="d-grid gap-2 mt-4">

    <a asp-page="/Setup/Locations/Actions/Edit"
    asp-route-locationId="@Model.Location.LocationId"
    asp-route-returnUrl="@(Model.ReturnUrl ?? Url.Page("/Setup/Locations/Index"))"
    class="btn btn-lg btn-primary">
        Edit location
    </a>

    <form method="post" class="d-grid">
        <button type="submit"
                asp-page-handler="ToggleActive"
                class="btn btn-lg @(Model.Location.IsActive ? "btn-outline-danger" : "btn-outline-success")"
                onclick="return confirm('Are you sure you want to @(Model.Location.IsActive ? "deactivate" : "reactivate") this location?');">
            @(Model.Location.IsActive ? "Deactivate location" : "Reactivate location")
        </button>
    </form>

</div>

<partial name="_BackFullWidth"
         model="@(Model.ReturnUrl ?? Url.Page("/Setup/Locations/Index"))" />