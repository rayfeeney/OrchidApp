<h1 class="page-title fw-bold">Repot status</h1>
<h2 class="h5 fw-bold mb-3">All plants</h2>

<form method="get">
    <div class="mb-3">
        <label class="fw-bold">Filter by genus</label>
        <select asp-for="GenusId"
                class="form-select"
                onchange="this.form.submit()">

            <option value="">All genera</option>

            @foreach (var g in Model.Genera)
            {
                <option value="@g.GenusId">
                    @g.GenusName
                </option>
            }
        </select>
    </div>
</form>

@if (!Model.Plants.Any())
{
    <div class="text-muted">No plants found.</div>
}
else
{
    @foreach (var plant in Model.Plants)
    {
        <a asp-page="/Plants/Details"
           asp-route-plantId="@plant.PlantId"
           class="btn btn-lg btn-outline-primary w-100 mb-2 text-start">

            <div class="fw-bold">
                @plant.DisplayName
            </div>

            <div>
                @plant.LocationName
            </div>

            <div class="text-muted">
                @plant.PlantTag
            </div>

            <div>
                @plant.RepotSummary
            </div>

        </a>
    }
}