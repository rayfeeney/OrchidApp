@page
@model OrchidApp.Web.Pages.Reports.Flowering.IndexModel

<div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center mb-3">

    <div>
        <h1 class="page-title fw-bold mb-0">Currently flowering</h1>
        <h2 class="h5 fw-bold mb-0">All plants</h2>
    </div>

    <a asp-page="/Reports/Index"
       class="btn btn-outline-secondary btn-lg mt-2 mt-sm-0">
        ← Reports
    </a>

</div>

@if (!Model.Plants.Any())
{
    <div class="text-muted">No plants currently flowering.</div>
}
else
{
    @foreach (var plant in Model.Plants)
    {
        <a asp-page="/Plants/Details"
           asp-route-plantId="@plant.PlantId"
           class="btn btn-lg btn-outline-primary w-100 mb-2 text-start">

            <div class="fw-bold">
                @plant.DisplayName
            </div>

            <div>
                @plant.LocationName
            </div>

            <div class="text-muted">
                @plant.PlantTag
            </div>

        </a>
    }
}

@{
    var backUrl = "/Reports";
}

<partial name="_BackFullWidth" model="backUrl" />