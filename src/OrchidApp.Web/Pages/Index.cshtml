@page
@model OrchidApp.Web.Pages.IndexModel

<h1 class="page-title fw-bold">Home</h1>

<p class="text-muted">
    Manage your orchid collection and care history.
</p>

<div class="d-grid gap-3 mt-4">

    <a asp-page="/Plants/Index"
       asp-route-returnUrl="@(Request.Path + Request.QueryString)"
       class="btn btn-lg btn-outline-primary">
       @* class="btn btn-lg btn-primary"> *@
        Plants
    </a>

    <a asp-page="/Reports/Index"
       asp-route-returnUrl="@(Request.Path + Request.QueryString)"
       class="btn btn-lg btn-outline-primary">
        Reports
    </a>

    <a asp-page="/Setup/Index"
       asp-route-returnUrl="@(Request.Path + Request.QueryString)"
       class="btn btn-lg btn-outline-primary">
        Setup
    </a>

</div>
