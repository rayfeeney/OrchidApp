<!DOCTYPE html>
<html lang="en">
@inject IWebHostEnvironment Env
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - OrchidApp</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/OrchidApp.Web.styles.css" asp-append-version="true" />
    <link rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
</head>

<body class="d-flex flex-column min-vh-100 @(Env.IsDevelopment() ? "env-dev" : "")">

    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom box-shadow">
            <div class="container">
                <a class="navbar-brand" asp-page="/Index">OrchidApp</a>
                <button class="navbar-toggler" type="button"
                        data-bs-toggle="collapse"
                        data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                    <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">

                        <!-- LEFT: Navigation -->
                        <ul class="navbar-nav flex-grow-1">
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-page="/Index">Home</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-page="/Plants/Index">Plants</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-page="/Setup/Index">Setup</a>
                            </li>
                        </ul>

                        <!-- RIGHT: Quick Find -->
                        <form method="get" action="/Plants/Tag" class="d-flex" role="search">

                            <input name="plantTag"
                                class="form-control me-2"
                                type="search"
                                placeholder="Search by tag"
                                aria-label="Plant tag"
                                style="max-width: 160px;"
                                oninput="this.value = this.value.toUpperCase()" />

                            <button class="btn btn-outline-primary" type="submit">
                                Find
                            </button>
                        </form>

                    </div>
            </div>
        </nav>
    </header>

    <main class="flex-fill d-flex flex-column">
        <div class="container py-4 flex-grow-1">
            @RenderBody()
        </div>
    </main>

    <footer class="border-top text-muted">
        <div class="container small text-center py-3">
            &copy; @DateTime.UtcNow.Year Raymond Feeney
            · <a asp-page="/Privacy">Privacy</a>
            · <a asp-page="/Legal/Licence">Source (AGPL v3.0)</a>
            · <a href="https://github.com/rayfeeney/OrchidApp"
                 target="_blank"
                 rel="noopener">Source Code</a>
        </div>
    </footer>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

</body>


</html>