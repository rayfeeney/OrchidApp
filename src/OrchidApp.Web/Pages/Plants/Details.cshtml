@page "{plantId:int}"
@model OrchidApp.Web.Pages.Plants.DetailsModel

@{
    if (Model.IsEnded)
    {
        ViewData["BodyClass"] = "plant-ended-bg";
    }
}

<div class="plant-page @(Model.IsEnded ? "plant-ended" : "")">
    
@{
    ViewData["Title"] = Model.StatusRequired.DisplayName;
}

<h1 class="page-title fw-bold @((Model.IsInactive || Model.IsEnded) ? "text-muted" : "")">
    @Model.StatusRequired.DisplayName

    @if (Model.IsInactive)
    {
        <span class="badge bg-secondary ms-2">Inactive</span>
    }
    @if (Model.IsEnded)
    {
        <span class="badge bg-dark ms-2">Ended</span>
    }
</h1>

<h2 class="h5 fw-bold mb-3">
    Plant details
</h2>

@if (Model.IsEnded)
{
    <div class="alert alert-secondary mt-3">
        This plant has ended and is read-only.
    </div>
}

<div class="row mt-3">

    <!-- Left column: details -->
    <div class="col-12 col-md-8">

        <div class="card">
            <div class="card-body">
                <dl class="row mb-0">

<dt class="col-sm-3 fw-bold">Plant tag</dt>
<dd class="col-sm-9 d-flex justify-content-between align-items-center">

    <span class="plant-tag">@Model.StatusRequired.PlantTag</span>

    <a asp-page="/Plants/Edit/Index"
    asp-route-plantId="@Model.StatusRequired.PlantId"
    class="btn btn-sm @(Model.IsEnded ? "btn-outline-secondary" : "btn-outline-primary") ms-2 px-3">

        <i class="bi @(Model.IsEnded ? "bi-eye" : "bi-pencil") me-1"></i>
        @(Model.IsEnded ? "View details" : "Edit")

    </a>

</dd>

                    <dt class="col-sm-3 fw-bold">Location</dt>
                    <dd class="col-sm-9">
                        @(string.IsNullOrWhiteSpace(Model.StatusRequired.LocationName)
                            ? "—"
                            : Model.StatusRequired.LocationName)
                    </dd>

                    @if (Model.StatusRequired.LastRepotDate != null)
                    {
                        <dt class="col-sm-3 fw-bold">Repotting</dt>
                        <dd class="col-sm-9">
                            @if (!string.IsNullOrWhiteSpace(Model.StatusRequired.CurrentGrowthMediumName))
                            {
                                @($"Repotted {Model.StatusRequired.LastRepotDate:dd/MM/yyyy} into {Model.StatusRequired.CurrentGrowthMediumName}")
                            }
                            else
                            {
                                @($"Repotted {Model.StatusRequired.LastRepotDate:dd/MM/yyyy}")
                            }
                        </dd>
                    }

                    @if (Model.StatusRequired.AcquisitionDate != null 
                        || !string.IsNullOrWhiteSpace(Model.StatusRequired.AcquisitionSource))
                    {
                        <dt class="col-sm-3 fw-bold">Acquisition</dt>
                        <dd class="col-sm-9">
                            @if (Model.StatusRequired.AcquisitionDate != null 
                                && !string.IsNullOrWhiteSpace(Model.StatusRequired.AcquisitionSource))
                            {
                                @($"Acquired {Model.StatusRequired.AcquisitionDate:dd/MM/yyyy} from {Model.StatusRequired.AcquisitionSource}")
                            }
                            else if (Model.StatusRequired.AcquisitionDate != null)
                            {
                                @($"Acquired {Model.StatusRequired.AcquisitionDate:dd/MM/yyyy}")
                            }
                            else
                            {
                                @($"Source: {Model.StatusRequired.AcquisitionSource}")
                            }
                        </dd>
                    }

                    @if (Model.StatusRequired.LastFeedDateTime != null)
                    {
                        <dt class="col-sm-3 fw-bold">Feeding</dt>
                        <dd class="col-sm-9">
                            @if (!string.IsNullOrWhiteSpace(Model.StatusRequired.LastFeedTypeDisplayName))
                            {
                                @($"Fed {Model.StatusRequired.LastFeedDateTime:dd/MM/yyyy} ({Model.StatusRequired.LastFeedTypeDisplayName})")
                            }
                            else
                            {
                                @($"Fed {Model.StatusRequired.LastFeedDateTime:dd/MM/yyyy}")
                            }
                        </dd>
                    }

                    @if (Model.StatusRequired.LastFloweringDate != null)
                    {
                        <dt class="col-sm-3 fw-bold">Flowering</dt>
                        <dd class="col-sm-9">
                            @($"Last flowered {Model.StatusRequired.LastFloweringDate:dd/MM/yyyy}")
                        </dd>
                    }

                </dl>
            </div>
        </div>

    </div>

    <!-- Right column: hero image -->
    @if (!string.IsNullOrWhiteSpace(Model.HeroFileName))
    {
        <div class="col-12 col-md-4 mt-3 mt-md-0 text-md-end">
            <a asp-page="/Plants/Photos/Index"
               asp-route-plantId="@Model.StatusRequired.PlantId"
               asp-route-returnUrl="@(Request.Path + Request.QueryString)"
               class="d-block w-100">

                <img src="~/@Model.HeroFileName"
                     class="img-fluid rounded shadow-sm w-100"
                     style="max-height:250px; object-fit:cover;" />
            </a>

            <p class="text-muted small mt-2 mb-0">
                Tap image to view photos
            </p>
        </div>
    }

</div>

@if (Model.StatusRequired.HasParent || Model.StatusRequired.HasChildren)
{
    <div class="card mt-3">
        <div class="card-body">

            <h2 class="h5 fw-bold mb-3">Heritage</h2>

            <div class="row g-3">

                <!-- LEFT: Parent -->
                <div class="col-12 col-md-6">

                    @if (Model.StatusRequired.HasParent)
                    {
                        <a asp-page="/Plants/Details"
                           asp-route-plantId="@Model.StatusRequired.ParentPlantId"
                           class="btn btn-outline-secondary w-100 text-start py-2">

                            <div class="d-flex justify-content-between align-items-center">

                                <div class="fw-bold">
                                    ↑ Parent
                                </div>

                                <div class="text-end">
                                    <div class="plant-tag">
                                        @Model.StatusRequired.ParentPlantTag
                                    </div>

                                    @if (Model.StatusRequired.AcquisitionDate != null)
                                    {
                                        <div class="text-muted small">
                                            Ended @Model.StatusRequired.AcquisitionDate.Value.ToString("dd/MM/yyyy")
                                        </div>
                                    }
                                </div>

                            </div>

                        </a>
                    }

                </div>

                <!-- RIGHT: Children -->
                <div class="col-12 col-md-6">

                    @if (Model.StatusRequired.HasChildren)
                    {
                        <div class="d-grid gap-2">

                            @foreach (var child in Model.ChildPlants)
                            {
                                <a asp-page="/Plants/Details"
                                   asp-route-plantId="@child.ChildPlantId"
                                   class="btn btn-outline-secondary w-100 text-start py-2">

                                    <div class="d-flex justify-content-between align-items-center">

                                        <div class="fw-bold">
                                            ↓ Child
                                        </div>

                                        <div class="text-end">
                                            <div class="plant-tag">
                                                @child.PlantTag
                                            </div>

                                            @if (child.AcquisitionDate != null)
                                            {
                                                <div class="text-muted small">
                                                    Created @child.AcquisitionDate.Value.ToString("dd/MM/yyyy")
                                                </div>
                                            }
                                        </div>

                                    </div>

                                </a>
                            }

                        </div>
                    }

                </div>

            </div>
            <div class="mt-3">

                <a asp-page="/Plants/Lineage"
                asp-route-plantId="@Model.StatusRequired.PlantId"
                asp-route-returnUrl="@(Request.Path + Request.QueryString)"
                class="btn btn-outline-primary w-100">

                    View full lineage

                </a>

            </div>

        </div>
    </div>
}

<h2 class="h5 fw-bold mb-3 mt-4">History</h2>

@if (!Model.IsEnded)
{
    <p class="text-muted small mb-3">
        Record observations (including photos), moves, repotting and flowering events.
    </p>

    <div class="d-grid gap-2 d-sm-flex mb-3">
        <a asp-page="/Plants/Events/Add"
        asp-route-eventType="Observation"
        asp-route-plantId="@Model.StatusRequired.PlantId"
        asp-route-returnUrl="@(Request.Path + Request.QueryString)"
        class="btn btn-primary">
            Add observation
        </a>

        <a asp-page="/Plants/Events/Add"
        asp-route-eventType="LocationChange"
        asp-route-plantId="@Model.StatusRequired.PlantId"
        asp-route-returnUrl="@(Request.Path + Request.QueryString)"
        class="btn btn-primary">
            Move plant
        </a>

        <a asp-page="/Plants/Events/Add"
        asp-route-eventType="Flowering"
        asp-route-plantId="@Model.StatusRequired.PlantId"
        asp-route-returnUrl="@(Request.Path + Request.QueryString)"
        class="btn btn-primary">
            Add flowering
        </a>

        <a asp-page="/Plants/Events/Add"
        asp-route-eventType="Repotting"
        asp-route-plantId="@Model.StatusRequired.PlantId"
        asp-route-returnUrl="@(Request.Path + Request.QueryString)"
        class="btn btn-primary">
            Add repotting
        </a>
    </div>
}

<hr class="my-4" />

@if (!Model.IsEnded)
{
    <div class="mb-4">

        <p class="text-muted small mb-2">
            Splitting ends this plant and creates new plants.
        </p>

        <a asp-page="/Plants/Events/Split"
        asp-route-plantId="@Model.StatusRequired.PlantId"
        asp-route-returnUrl="@(Request.Path + Request.QueryString)"
        class="btn btn-outline-secondary btn-lg w-100">
            Split plant
        </a>

    </div>
}

@if (!Model.LifecycleEvents.Any())
{
    <p class="text-muted">No events recorded yet.</p>
}
else
{
    
        <div class="d-grid gap-3">
        @foreach (var ev in Model.LifecycleEvents)
        {
            <div class="card">
                <div class="card-body">

                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <div class="d-flex justify-content-between align-items-start gap-3">

                                <div class="d-flex align-items-center gap-2">

                                    @{
                                        var badgeClass = "bg-secondary";
                                        var iconClass = "bi-journal-text";
                                        var label = ev.EventType;

                                        if (ev.EventType == "LocationChange")
                                        {
                                            badgeClass = "bg-info text-dark";
                                            iconClass = "bi-geo-alt";
                                            label = "Move";
                                        }
                                        else if (ev.EventType == "Flowering")
                                        {
                                            badgeClass = "bg-success";
                                            iconClass = "bi-flower1";
                                        }
                                        else if (ev.EventType == "Repotting")
                                        {
                                            badgeClass = "bg-warning text-dark";
                                            iconClass = "bi-arrow-repeat";
                                        }
                                    }

                                    <span class="badge @badgeClass">
                                        <i class="bi @iconClass me-1"></i>
                                        @label
                                    </span>

                                </div>

                                <div class="text-muted small text-nowrap">
                                    @ev.EventDateTime.ToString("dd/MM/yyyy")
                                </div>

                            </div>
                        </div>
                    </div>

                    <div class="mt-3">

                        @if (!string.IsNullOrWhiteSpace(ev.EventSummary))
                        {
                            <div class="event-summary">
                                @ev.EventSummary
                            </div>
                        }
                        else
                        {
                            <div class="text-muted">
                                No additional details recorded.
                            </div>
                        }

                    </div>

                    @if (!Model.IsEnded)
                    {
                        <div class="d-flex gap-2 mt-3">
                            <a asp-page="/Plants/Events/Edit"
                            asp-route-plantId="@Model.StatusRequired.PlantId"
                            asp-route-sourceId="@ev.SourceId"
                            asp-route-eventType="@ev.EventType"
                            asp-route-returnUrl="@(Request.Path + Request.QueryString)"
                            class="btn btn-sm btn-outline-secondary">
                                Edit event
                            </a>

                            <a asp-page="/Plants/Events/Remove"
                            asp-route-plantId="@Model.StatusRequired.PlantId"
                            asp-route-sourceId="@ev.SourceId"
                            asp-route-eventType="@ev.EventType"
                            asp-route-returnUrl="@(Request.Path + Request.QueryString)"
                            class="btn btn-sm btn-outline-danger">
                                Remove event
                            </a>
                        </div>
                    }
                </div>
            </div>
        }
        </div>

}

<partial name="_BackFullWidth"
         model="@(Model.ReturnUrl ?? Url.Page("/Plants/Index"))" />
</div>