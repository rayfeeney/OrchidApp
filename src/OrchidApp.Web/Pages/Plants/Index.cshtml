@page
@model OrchidApp.Web.Pages.Plants.IndexModel

@{
    ViewData["Title"] = "Plants";
}

<h1 class="page-title fw-bold">Plants</h1>

<h2 class="h5 fw-bold mb-3">
View and manage your collection
</h2>

<p class="text-muted small">
Select a species / hybrid to view its plants.
</p>

<div class="d-grid gap-2 mb-4">
    <a asp-page="/Plants/Add/Index"
       asp-route-returnUrl="@(Request.Path + Request.QueryString)"
       class="btn btn-primary btn-lg">
        Add plant
    </a>
</div>

<div class="d-grid gap-2">
@foreach (var genusGroup in Model.Taxa.GroupBy(t => new { t.GenusName, t.GenusIsActive }))
{
    <h2 class="h6 fw-bold mt-4 mb-2 @(genusGroup.Key.GenusIsActive ? "" : "text-muted")">
        @genusGroup.Key.GenusName

        @if (!genusGroup.Key.GenusIsActive)
        {
            <span class="badge bg-secondary ms-2">Inactive</span>
        }
    </h2>

    <div class="d-grid gap-2">
        @foreach (var taxon in genusGroup)
{
    var isInactive = !taxon.GenusIsActive || !taxon.TaxonIsActive;

            <a asp-page="/Plants/Taxon"
            asp-route-taxonId="@taxon.TaxonId"
            asp-route-returnUrl="@(Request.Path + Request.QueryString)"
            class="btn btn-outline-primary btn-lg text-start d-flex justify-content-between align-items-center @(isInactive ? "text-muted" : "")">

                <span>
                    @taxon.DisplayName

                    @if (isInactive)
                    {
                        <span class="badge bg-secondary ms-2">Inactive</span>
                    }
                </span>
                <span class="badge bg-secondary">
                    @taxon.PlantCount plant@(taxon.PlantCount == 1 ? "" : "s")
                </span>
            </a>
        }
    </div>
}
</div>

<partial name="_BackFullWidth"
         model="@(Model.ReturnUrl ?? Url.Page("/Index"))" />