@page "/Plants/Add/Create/{taxonId:int}"
@model OrchidApp.Web.Pages.Plants.Add.CreateModel

@{
    ViewData["Title"] = "Add plant";
}

<h1 class="page-title fw-bold">Add plant</h1>

@if (Model.Taxon != null)
{
    <h2 class="h5 fw-bold mb-3">
        @Model.Taxon.DisplayName
    </h2>
}

<p class="text-muted small mb-3">
This plant will be recorded under this species / hybrid. You can edit these details later if needed.
</p>

<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

<form method="post">

    <div class="mb-3">
        <label asp-for="Input.PlantTag" class="fw-bold"></label>
        <small class="text-muted d-block fw-normal">
            Every plant needs a unique tag. It can contain any characters.
        </small>
        <input asp-for="Input.PlantTag" class="form-control" />
        <span asp-validation-for="Input.PlantTag" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Input.PlantName" class="fw-bold"></label>
        <small class="text-muted d-block fw-normal">
            Optional. A personal name to help you recognise this plant.
        </small>
        <input asp-for="Input.PlantName" class="form-control" />
        <span asp-validation-for="Input.PlantName" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Input.AcquisitionDate" class="fw-bold"></label>
        <small class="text-muted d-block fw-normal">
            Optional. The date you obtained the plant.
        </small>
        <input asp-for="Input.AcquisitionDate" class="form-control" />
        <span asp-validation-for="Input.AcquisitionDate" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Input.AcquisitionSource" class="fw-bold"></label>
        <small class="text-muted d-block fw-normal">
            Optional. Where the plant came from (e.g. nursery, friend, swap).
        </small>
        <input asp-for="Input.AcquisitionSource" class="form-control" />
        <span asp-validation-for="Input.AcquisitionSource" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Input.PlantNotes" class="fw-bold"></label>
        <small class="text-muted d-block fw-normal">
            Optional. Any additional notes about this plant.
        </small>
        <textarea asp-for="Input.PlantNotes"
                  class="form-control"
                  rows="4"></textarea>
        <span asp-validation-for="Input.PlantNotes" class="text-danger"></span>
    </div>

    <partial name="_FormActions"
             model="@(Model.ReturnUrl ?? Url.Page("/Plants/Add/Index"), "Add plant")" />

</form>