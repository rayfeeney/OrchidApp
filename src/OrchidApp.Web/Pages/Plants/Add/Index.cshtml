@page
@model OrchidApp.Web.Pages.Plants.Add.IndexModel

@{
    ViewData["Title"] = "Add plant";
}

<h1 class="page-title fw-bold">Add plant</h1>

<h2 class="h5 fw-bold mb-3">
Select the genus and species / hybrid
</h2>

<p class="text-muted small mb-3">
Choose the botanical name for the new plant.
You’ll enter the plant’s details next.
</p>

<div class="d-grid gap-2">
@foreach (var genusGroup in Model.Taxa.GroupBy(t => t.GenusName))
{
    <h2 class="h6 fw-bold mt-4 mb-2">@genusGroup.Key</h2>

    <div class="d-grid gap-2">
        @foreach (var taxon in genusGroup)
        {
            <a asp-page="/Plants/Add/Create"
               asp-route-taxonId="@taxon.TaxonId"
               asp-route-returnUrl="@(Request.Path + Request.QueryString)"
               class="btn btn-outline-primary btn-lg text-start d-flex">
               <div class="d-flex align-items-center gap-3">

<div class="d-flex flex-column align-items-center flex-shrink-0">

    @if (!string.IsNullOrWhiteSpace(taxon.ThumbnailFileName))
    {
        <img src="~/uploads/taxa/@taxon.TaxonId/@taxon.ThumbnailFileName"
             style="width:64px; height:64px; object-fit:cover;"
             class="rounded border" />

        <small class="text-muted d-block text-center" style="font-size:0.7rem;">
            reference image
        </small>
    }
    else
    {
        <div style="width:64px; height:64px;"
             class="bg-light border rounded d-flex align-items-center justify-content-center">
            —
        </div>
    }

</div>

                    <span>@taxon.DisplayName</span>

                </div>
            </a>
        }
    </div>
}
</div>

<partial name="_BackFullWidth"
         model="@(Model.ReturnUrl ?? Url.Page("/Plants/Index"))" />
