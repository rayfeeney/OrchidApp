@page
@model OrchidApp.Web.Pages.Plants.Add.IndexModel

@{
    ViewData["Title"] = "Add plant";
}

<h1>Add plant</h1>

<p class="text-muted">
    Choose the genus and species/hybrid for the new plant.
</p>

<div class="d-grid gap-2">
@foreach (var genusGroup in Model.Taxa.GroupBy(t => t.GenusName))
{
    <h2 class="mt-4">@genusGroup.Key</h2>

    <div class="d-grid gap-2">
        @foreach (var taxon in genusGroup)
        {
            <a asp-page="/Plants/Add/Create"
               asp-route-taxonId="@taxon.TaxonId"
               asp-route-returnUrl="@(Request.Path + Request.QueryString)"
               class="btn btn-outline-primary btn-lg text-start">
                @taxon.DisplayName
            </a>
        }
    </div>
}
</div>

<partial name="_BackFullWidth"
         model="@(Model.ReturnUrl ?? Url.Page("/Plants/Index"))" />
