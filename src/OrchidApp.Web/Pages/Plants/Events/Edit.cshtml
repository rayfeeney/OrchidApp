@page "/Plants/Events/Edit/{plantId:int}/{sourceId:int}"
@model OrchidApp.Web.Pages.Plants.Events.EditModel

@{
    ViewData["Title"] = Model.EventType switch
    {
        "Observation"    => "Edit observation",
        "LocationChange" => "Edit move",
        "Flowering"      => "Edit flowering",
        "Repotting"      => "Edit repotting",
        _                => throw new InvalidOperationException("Unknown event type.")
    };
}


<h1 class="page-title fw-bold @(Model.IsInactive ? "text-muted" : "")">
    @ViewData["Title"]

    @if (Model.IsInactive)
    {
        <span class="badge bg-secondary ms-2">Inactive</span>
    }
</h1>

@if (Model.PlantDisplayName != null)
{
    <h2 class="h5 fw-bold mb-1 @(Model.IsInactive ? "text-muted" : "")">
        @Model.PlantDisplayName
    </h2>

    <div class="plant-tag mb-3">@Model.PlantTag</div>
}

@if (Model.EventType == "Observation")
{
    <p class="text-muted small mb-3">
        Update details of this observation.
    </p>
}

@if (Model.EventType == "LocationChange")
{
    <p class="text-muted small mb-3">
        Adjust when this plant was moved. Previous location history will be preserved.
    </p>
}

@if (Model.EventType == "Flowering")
{
    <p class="text-muted small mb-3">
        Update this flowering record.
    </p>
}

@if (Model.EventType == "Repotting")
{
    <p class="text-muted small mb-3">
        Update this repotting record.
    </p>
}

<div asp-validation-summary="ModelOnly"
     class="text-danger mb-3"></div>

<form method="post">
    <input type="hidden" asp-for="EventType" />

    @if (Model.EventType == "Observation")
    {
        <div class="mb-3">
            <label asp-for="EventDate" class="fw-bold">Observed on</label>
            <input asp-for="EventDate"
                   type="date"
                   class="form-control"
                   asp-format="{0:yyyy-MM-dd}" />
            <span asp-validation-for="EventDate" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="EventDetails" class="fw-bold">Notes</label>
            <textarea asp-for="EventDetails"
                      class="form-control"
                      rows="4"></textarea>
        </div>
    }

    @if (Model.EventType == "LocationChange")
    {
        <div class="mb-3">
            <label asp-for="EventDate" class="fw-bold">Moved on</label>
            <input asp-for="EventDate"
                   type="date"
                   class="form-control"
                   asp-format="{0:yyyy-MM-dd}" />
            <span asp-validation-for="EventDate" class="text-danger"></span>
        </div>

        @* Future: MoveReasonCode *@
        @*
        <div class="mb-3">
            <label asp-for="MoveReasonCode" class="fw-bold">Move reason</label>
            <select asp-for="MoveReasonCode" class="form-select"></select>
        </div>
        *@

        <div class="mb-3">
            <label asp-for="EventDetails" class="fw-bold">Reason for move</label>
            <textarea asp-for="EventDetails"
                      class="form-control"
                      rows="3"></textarea>
        </div>

        <div class="mb-3">
            <label asp-for="PlantLocationNotes" class="fw-bold">Location notes</label>
            <textarea asp-for="PlantLocationNotes"
                      class="form-control"
                      rows="3"></textarea>
        </div>
    }

    @if (Model.EventType == "Flowering")
    {
        <div class="mb-3">
            <label asp-for="EventDate" class="fw-bold">Flowering started on</label>
            <input asp-for="EventDate"
                   type="date"
                   class="form-control"
                   asp-format="{0:yyyy-MM-dd}" />
            <span asp-validation-for="EventDate" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="EndDate" class="fw-bold">Flowering ended on</label>
            <input asp-for="EndDate"
                   type="date"
                   class="form-control"
                   asp-format="{0:yyyy-MM-dd}" />
            <span asp-validation-for="EndDate" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="SpikeCount" class="fw-bold">Spike count</label>
            <input asp-for="SpikeCount"
                   type="number"
                   class="form-control" />
        </div>

        <div class="mb-3">
            <label asp-for="FlowerCount" class="fw-bold">Flower count</label>
            <input asp-for="FlowerCount"
                   type="number"
                   class="form-control" />
        </div>

        <div class="mb-3">
            <label asp-for="EventDetails" class="fw-bold">Notes</label>
            <textarea asp-for="EventDetails"
                      class="form-control"
                      rows="3"></textarea>
        </div>
    }

    @* Repotting *@
    @if (Model.EventType == "Repotting")
    {
        <div class="mb-3">
            <label asp-for="EventDate" class="fw-bold">Repot date</label>
            <input asp-for="EventDate"
                   type="date"
                   class="form-control" />
            <span asp-validation-for="EventDate" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="OldGrowthMediumId" class="fw-bold">Previous medium</label>
            <select asp-for="OldGrowthMediumId" class="form-select">
                <option value="">—</option>
                @foreach (var medium in Model.GrowthMedia)
                {
                    <option value="@medium.GrowthMediumId">
                        @medium.Name
                    </option>
                }
            </select>
        </div>

        <div class="mb-3">
            <label asp-for="OldMediumNotes" class="fw-bold">Previous medium notes</label>
            <textarea asp-for="OldMediumNotes"
                      class="form-control"
                      rows="3"></textarea>
        </div>

        <div class="mb-3">
            <label asp-for="NewGrowthMediumId" class="fw-bold">New medium</label>
            <select asp-for="NewGrowthMediumId" class="form-select">
                <option value="">—</option>
                @foreach (var medium in Model.GrowthMedia)
                {
                    <option value="@medium.GrowthMediumId">
                        @medium.Name
                    </option>
                }
            </select>
        </div>

        <div class="mb-3">
            <label asp-for="NewMediumNotes" class="fw-bold">New medium notes</label>
            <textarea asp-for="NewMediumNotes"
                      class="form-control"
                      rows="3"></textarea>
        </div>

        <div class="mb-3">
            <label asp-for="PotSize" class="fw-bold">Pot size</label>
            <input asp-for="PotSize"
                   class="form-control" />
        </div>

        <div class="mb-3">
            <label asp-for="RepotReasonNotes" class="fw-bold">Reason for repotting</label>
            <textarea asp-for="RepotReasonNotes"
                      class="form-control"
                      rows="3"></textarea>
        </div>

        <div class="mb-3">
            <label asp-for="RepottingNotes" class="fw-bold">Additional notes</label>
            <textarea asp-for="RepottingNotes"
                      class="form-control"
                      rows="3"></textarea>
        </div>
    }

    <partial name="_FormActions"
            model="@(Model.ReturnUrl 
                    ?? Url.Page("/Plants/Details", new { plantId = Model.PlantId }), 
                    ViewData["Title"]?.ToString() ?? "Save changes")" />

</form>