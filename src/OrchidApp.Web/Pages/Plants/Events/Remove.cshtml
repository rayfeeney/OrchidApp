@page "/Plants/Events/Remove/{plantId:int}/{sourceId:int}"
@model OrchidApp.Web.Pages.Plants.Events.RemoveModel

@{
    ViewData["Title"] = Model.EventType switch
    {
        "Observation"    => "Remove observation",
        "LocationChange" => "Remove location",
        "Flowering"      => "Remove flowering",
        "Repotting"      => "Remove repotting",
        _                => "Remove event"
    };
}

<h1 class="page-title fw-bold @(Model.IsInactive ? "text-muted" : "")">
    @ViewData["Title"]

    @if (Model.IsInactive)
    {
        <span class="badge bg-secondary ms-2">Inactive</span>
    }
</h1>

@if (Model.PlantDisplayName != null)
{
    <h2 class="h5 fw-bold mb-3 @(Model.IsInactive ? "text-muted" : "")">
        @Model.PlantDisplayName

        @if (Model.IsInactive)
        {
            <span class="badge bg-secondary ms-2">Inactive</span>
        }

        @if (!string.IsNullOrWhiteSpace(Model.PlantTag))
        {
            <span class="fw-normal text-muted">
                (Tag: @Model.PlantTag)
            </span>
        }
    </h2>
}

<h2 class="h5 fw-bold mb-3">
Confirm removal
</h2>

<p class="text-muted small mb-3">
This event will be permanently removed from the plant’s history.
</p>

<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

<div class="card mt-3 mb-3">
    <div class="card-body">
        <dl class="row mb-0">

            @{
                var eventLabel = Model.Event!.EventType switch
                {
                    "Observation"    => "Observation",
                    "LocationChange" => "Move",
                    "Flowering"      => "Flowering",
                    "Repotting"      => "Repotting",
                    _                => Model.Event.EventType
                };
            }

            <dt class="col-sm-3 fw-bold">Event</dt>
            <dd class="col-sm-9">
                @eventLabel
            </dd>

            <dt class="col-sm-3 fw-bold">Date</dt>
            <dd class="col-sm-9">
                @Model.Event.EventDateTime.ToString("dd/MM/yyyy")
            </dd>

            <dt class="col-sm-3 fw-bold">Summary</dt>
            <dd class="col-sm-9">
                @(string.IsNullOrWhiteSpace(Model.Event.EventSummary)
                    ? "—"
                    : Model.Event.EventSummary)
            </dd>

        </dl>
    </div>
</div>

<form method="post">
    <input type="hidden" asp-for="EventType" />

    <partial name="_FormActionsDanger"
             model="@(Model.ReturnUrl 
                      ?? Url.Page("/Plants/Details", new { plantId = Model.PlantId }),
                      "Remove event")" />
</form>