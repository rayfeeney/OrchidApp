@page "/Plants/Events/Remove/{plantId:int}/{sourceId:int}"
@model OrchidApp.Web.Pages.Plants.Events.RemoveModel

@{
    ViewData["Title"] = Model.EventType switch
    {
        "Observation"    => "Remove Observation Record",
        "LocationChange" => "Remove Location Record",
        "Flowering"      => "Remove Flowering Record",
        "Repotting"      => "Remove Repotting Record",
        _                => "Remove Event Record"
    };
}

<h1 class="page-title fw-bold">@ViewData["Title"]</h1>

<h2 class="h5 fw-bold mb-3">
    <span class="fw-normal text-muted">
        You are about to remove the following:
    </span>
</h2>

<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

<div class="card mt-3 mb-3">
    <div class="card-body">
        <dl class="row mb-0">

            <dt class="col-sm-3 fw-bold">Event</dt>
            <dd class="col-sm-9">
                @Model.Event!.EventType
            </dd>

            <dt class="col-sm-3 fw-bold">Date</dt>
            <dd class="col-sm-9">
                @Model.Event.EventDateTime.ToString("dd/MM/yyyy")
            </dd>

            <dt class="col-sm-3 fw-bold">Summary</dt>
            <dd class="col-sm-9">
                @(string.IsNullOrWhiteSpace(Model.Event.EventSummary)
                    ? "—"
                    : Model.Event.EventSummary)
            </dd>

        </dl>
    </div>
</div>

<form method="post">
    <input type="hidden" asp-for="EventType" />

    <partial name="_FormActionsDanger"
             model="@(Model.ReturnUrl 
                      ?? Url.Page("/Plants/Details", new { plantId = Model.PlantId }),
                      "Confirm remove")" />
</form>