@page "{plantId:int}"
@model OrchidApp.Web.Pages.Plants.Events.SplitModel

<h1 class="page-title fw-bold">Split plant</h1>

<h2 class="h5 fw-bold mb-3">
    <span>@Model.Plant?.DisplayName</span>
    @if (!string.IsNullOrWhiteSpace(Model.Plant?.PlantTag))
    {
        <span class="fw-normal text-muted">
            (@Model.Plant.PlantTag)
        </span>
    }
</h2>

<p class="text-muted">
    This split will end this plant’s lifecycle at the date and time you choose
    and create new independent plants.
    The original plant will remain in your records and its full history
    will still be available to view.
</p>

<p class="text-muted small mb-3">
    This action cannot be undone.
</p>

<div asp-validation-summary="All" class="text-danger mb-3"></div>

<form method="post">

    <div class="mb-3">
        <label asp-for="SplitDateTime" class="fw-bold">
            Split date and time
        </label>
        <input asp-for="SplitDateTime"
               type="datetime-local"
               class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="SplitReasonNotes" class="fw-bold">
            Reason for split (optional)
        </label>
        <textarea asp-for="SplitReasonNotes"
                  class="form-control"
                  rows="3"></textarea>
    </div>

    <input type="hidden" asp-for="PlantId" />
    <input type="hidden" asp-for="ChildCount" />

    <h2 class="h5 fw-bold mt-4 mb-3">
    New plants
    </h2>

    <p class="text-muted small mb-3">
    Enter the details for each new plant created by this split.
    </p>

    @for (int i = 0; i < Model.ChildCount; i++)
    {
        <div class="card mb-3">
            <div class="card-header fw-bold">
                New plant @(@i + 1)
            </div>

            <div class="card-body">

                <div class="mb-3">
                    <label asp-for="Children[i].PlantTag" class="fw-bold"></label>
                    <small class="text-muted d-block fw-normal">
                        Required. Must be unique within your collection.
                    </small>
                    <input asp-for="Children[i].PlantTag"
                        class="form-control" />
                    <span asp-validation-for="Children[i].PlantTag"
                        class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Children[i].PlantName" class="fw-bold"></label>
                    <small class="text-muted d-block fw-normal">
                        Optional. A personal name to help you recognise this plant.
                    </small>
                    <input asp-for="Children[i].PlantName"
                        class="form-control" />
                    <span asp-validation-for="Children[i].PlantName"
                        class="text-danger"></span>
                </div>

            </div>
        </div>
    }

    <div class="mb-4">
        <button type="submit"
                asp-page-handler="AddChild"
                class="btn btn-outline-secondary w-100">
            Add another new plant
        </button>
    </div>

    <div class="mt-4">
        <partial name="_FormActionsDangerHandler"
                 model="@(Model.ReturnUrl
                         ?? Url.Page("/Plants/Details", new { plantId = Model.PlantId }),
                         "Split",
                         "Confirm split")" />
    </div>

</form>