@page "{plantId:int}"
@model OrchidApp.Web.Pages.Plants.Events.SplitModel

<h1 class="page-title fw-bold">Split plant</h1>

<h2 class="h5 fw-bold mb-3 @(Model.IsInactive ? "text-muted" : "")">
    <span>@Model.Plant?.DisplayName</span>

    @if (Model.IsInactive)
    {
        <span class="badge bg-secondary ms-2">Inactive</span>
    }
    @if (!string.IsNullOrWhiteSpace(Model.Plant?.PlantTag))
    {
        <span class="fw-normal text-muted">
            (@Model.Plant.PlantTag)
        </span>
    }
</h2>

<p class="text-muted">
    This split will end this plant’s lifecycle on the date and you choose
    and create new independent plants.
    The original plant will remain in your records and its full history
    will still be available to view.
</p>

<p class="text-muted small mb-3">
    New plants will be given permanent IDs automatically.
</p>

<div asp-validation-summary="All" class="text-danger mb-3"></div>

@if (Model.IsInactive)
{
    <div class="alert alert-secondary">
        This plant cannot be split because its taxonomy (Genus / Species / Hybrid) is inactive.
    </div>
}
else
{
<form method="post">

    <input type="hidden" asp-for="PlantId" />
    <input type="hidden" asp-for="ChildCount" />

    <div class="mb-3">
        <label asp-for="SplitDateTime" class="fw-bold">Split date</label>
        <input asp-for="SplitDateTime" type="date" class="form-control" />
        <span asp-validation-for="SplitDateTime" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="SplitReasonNotes" class="fw-bold">Reason for split</label>
        <small class="text-muted d-block fw-normal">
            Optional. Use this to record why the plant was divided.
        </small>
        <textarea asp-for="SplitReasonNotes" class="form-control" rows="3"></textarea>
        <span asp-validation-for="SplitReasonNotes" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="SplitNotes" class="fw-bold">Split notes</label>
        <small class="text-muted d-block fw-normal">
            Optional. Any additional notes about the outcome of the split.
        </small>
        <textarea asp-for="SplitNotes" class="form-control" rows="3"></textarea>
        <span asp-validation-for="SplitNotes" class="text-danger"></span>
    </div>

    <h2 class="h5 fw-bold mt-4 mb-3">New plants</h2>

    <p class="text-muted small mb-3">
        Two new plants are shown by default. Add more if needed.
        Plant permanent IDs will be created automatically.
    </p>

    @for (int i = 0; i < Model.ChildCount; i++)
    {
        <div class="card mb-3">
            <div class="card-header fw-bold">
                New plant @(@i + 1)
            </div>

            <div class="card-body">
                <div class="mb-3">
                    <label asp-for="Children[i].PlantName" class="fw-bold"></label>
                    <small class="text-muted d-block fw-normal">
                        Optional. A personal name to help you recognise this plant.
                    </small>
                    <input asp-for="Children[i].PlantName" class="form-control" />
                    <span asp-validation-for="Children[i].PlantName" class="text-danger"></span>
                </div>
            </div>
        </div>
    }

    <div class="mb-4">
        <button type="submit"
                asp-page-handler="AddChild"
                class="btn btn-outline-secondary w-100">
            Add another new plant
        </button>
    </div>

    <div class="alert alert-warning">
        This will permanently end this plant and create new plants.
        This action cannot be undone.
    </div>

    <div class="mt-4">
        <partial name="_FormActionsDangerHandler"
                model="@(Model.ReturnUrl
                        ?? Url.Page("/Plants/Details", new { plantId = Model.PlantId }),
                        "Split",
                        "Confirm split (ends this plant)")" />
    </div>

</form>
}