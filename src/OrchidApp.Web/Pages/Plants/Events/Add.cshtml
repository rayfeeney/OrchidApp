@page "/Plants/Events/Add/{plantId:int}/{eventType?}"
@model OrchidApp.Web.Pages.Plants.Events.AddModel

@{
    ViewData["Title"] = Model.EventType switch
    {
        "Observation" => "Add Observation",
        "LocationChange" => "Move Plant",
        "Flowering" => "Add Flowering",
        "Repotting" => "Add Repotting",
        _ => "Add Event"
    };
}

<h1 class="page-title fw-bold @(Model.IsInactive ? "text-muted" : "")">
    @ViewData["Title"]

    @if (Model.IsInactive)
    {
        <span class="badge bg-secondary ms-2">Inactive</span>
    }
</h1>

@if (Model.PlantDisplayName != null)
{
    <h2 class="h5 fw-bold mb-3 @(Model.IsInactive ? "text-muted" : "")">
        @Model.PlantDisplayName

        @if (Model.IsInactive)
        {
            <span class="badge bg-secondary ms-2">Inactive</span>
        }
        @if (!string.IsNullOrWhiteSpace(Model.PlantTag))
        {
            <span class="fw-normal text-muted">
                (Tag: @Model.PlantTag)
            </span>
        }
    </h2>

    @if (Model.EventType == "Observation")
    {
        <p class="text-muted small mb-3">
            Record something you’ve noticed about this plant.
        </p>
    }

    @if (Model.EventType == "LocationChange")
    {
        <p class="text-muted small mb-3">
            Record that this plant has been moved to a new location.
        </p>
    }

    @if (Model.EventType == "Flowering")
    {
        <p class="text-muted small mb-3">
            Record a flowering period for this plant.
        </p>
    }

    @if (Model.EventType == "Repotting")
    {
        <p class="text-muted small mb-3">
            Record when this plant was repotted and the growing medium used.
            Repotting history helps track root health and understand how long
            a plant has been in its current medium.
        </p>
    }
}

<div asp-validation-summary="ModelOnly"
     class="text-danger mb-3"></div>

<form method="post" enctype="multipart/form-data">

    @* Observation *@
    @if (Model.EventType == "Observation")
    {
        <div class="mb-3 d-grid gap-2">

        <p class="text-muted small mb-2">
        Choose a quick action or add general notes below.
        </p>

            <button type="submit"
                    name="quickAction"
                    value="photo"
                    class="btn btn-outline-primary">
                📷 Add photo
            </button>

            <button type="submit"
                    name="quickAction"
                    value="feedGrowth"
                    class="btn btn-outline-primary">
                🌱 Feed (growth)
            </button>

            <button type="submit"
                    name="quickAction"
                    value="feedBloom"
                    class="btn btn-outline-primary">
                🌸 Feed (bloom)
            </button>

        </div>

        <div class="mb-3">
            <label asp-for="EventDate" class="fw-bold">Observation date</label>
            <input asp-for="EventDate"
                   type="date"
                   class="form-control"
                   asp-format="{0:yyyy-MM-dd}" />
        </div>

        @if (Model.ShowPhotoSection)
        {
            <div class="mb-3">
                <label asp-for="UploadedFiles" class="fw-bold">Photos</label>
                <input asp-for="UploadedFiles"
                    type="file"
                    multiple
                    class="form-control" />
                <span asp-validation-for="UploadedFiles" class="text-danger"></span>
            </div>
        }

        <div class="mb-3">
            <label asp-for="EventDetails" class="fw-bold">Notes</label>
            <textarea asp-for="EventDetails"
                      class="form-control"
                      rows="4"
                      placeholder="e.g. Noticed new root growth, leaves firm and glossy"></textarea>
        </div>
    }

    @* LocationChange *@
    @if (Model.EventType == "LocationChange")
    {

    <p class="text-muted small mb-3">
    This records when the plant moved. Previous locations will be kept in its history.
    </p>

        <div class="mb-3">
            <label asp-for="LocationId" class="fw-bold">Location</label>
            <select asp-for="LocationId" class="form-select">
                <option value="">-- select location --</option>
                @foreach (var loc in Model.Locations)
                {
                    <option value="@loc.LocationId">@loc.LocationName</option>
                }
            </select>
            <span asp-validation-for="LocationId" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="EventDate" class="fw-bold">Move date</label>
            <input asp-for="EventDate"
                   type="date"
                   class="form-control" />
        </div>

        <div class="mb-3">
            <label asp-for="EventDetails" class="fw-bold">Move reason</label>
            <textarea asp-for="EventDetails" class="form-control"></textarea>
        </div>

        <div class="mb-3">
            <label asp-for="PlantLocationNotes" class="fw-bold">Location notes</label>
            <textarea asp-for="PlantLocationNotes" class="form-control"></textarea>
        </div>
    }

    @* Flowering *@
    @if (Model.EventType == "Flowering")
    {
        <div class="mb-3">
            <label asp-for="StartDate" class="fw-bold">Start date</label>
            <small class="text-muted d-block fw-normal">
            Date flowering began.
            </small>
            <input asp-for="StartDate"
                   type="date"
                   class="form-control" />
        </div>

        <div class="mb-3">
            <label asp-for="EndDate" class="fw-bold">End date (optional)</label>
            <input asp-for="EndDate"
                   type="date"
                   class="form-control" />
            <small class="text-muted d-block fw-normal">
                Leave blank if currently flowering.
            </small>
        </div>

        <div class="mb-3">
            <label asp-for="SpikeCount" class="fw-bold">Spike count</label>
            <input asp-for="SpikeCount"
                   type="number"
                   class="form-control" />
        </div>

        <div class="mb-3">
            <label asp-for="FlowerCount" class="fw-bold">Flower count</label>
            <input asp-for="FlowerCount"
                   type="number"
                   class="form-control" />
        </div>

        <div class="mb-3">
            <label asp-for="EventDetails" class="fw-bold">Notes</label>
            <textarea asp-for="EventDetails"
                      class="form-control"
                      rows="4"></textarea>
        </div>
    }

    @* Repotting *@
    @if (Model.EventType == "Repotting")
    {
        <div class="mb-3">
            <label asp-for="EventDate" class="fw-bold">Repotting date</label>
            <small class="text-muted d-block fw-normal">
                The date the plant was repotted.
            </small>
            <input asp-for="EventDate"
                type="date"
                class="form-control" />
        </div>

        <hr class="my-4" />

        <h3 class="h6 fw-bold">Previous growing medium</h3>

        <div class="mb-3">
            <label asp-for="OldGrowthMediumId" class="fw-bold">Medium</label>
            <small class="text-muted d-block fw-normal">
                The medium the plant was growing in before repotting.
            </small>
            <select asp-for="OldGrowthMediumId" class="form-select">
                <option value="">— unknown or not recorded —</option>
                @foreach (var medium in Model.GrowthMedia)
                {
                    <option value="@medium.GrowthMediumId">
                        @medium.Name
                    </option>
                }
            </select>
        </div>

        <div class="mb-3">
            <label asp-for="OldMediumNotes" class="fw-bold">Condition notes</label>
            <small class="text-muted d-block fw-normal">
                Optional notes such as broken down bark, compacted moss, or root condition.
            </small>
            <textarea asp-for="OldMediumNotes"
                    class="form-control"
                    rows="3"></textarea>
        </div>

        <hr class="my-4" />

        <h3 class="h6 fw-bold">New pot and medium</h3>

        <div class="mb-3">
            <label asp-for="NewGrowthMediumId" class="fw-bold">New growing medium</label>
            <small class="text-muted d-block fw-normal">
                The medium used after repotting.
            </small>
            <select asp-for="NewGrowthMediumId" class="form-select">
                <option value="">-- select medium --</option>
                @foreach (var medium in Model.GrowthMedia)
                {
                    <option value="@medium.GrowthMediumId">
                        @medium.Name
                    </option>
                }
            </select>
        </div>

        <div class="mb-3">
            <label asp-for="NewMediumNotes" class="fw-bold">Medium notes</label>
            <small class="text-muted d-block fw-normal">
                Optional details such as bark size, moss mix, or additives used.
            </small>
            <textarea asp-for="NewMediumNotes"
                    class="form-control"
                    rows="3"></textarea>
        </div>

        <div class="mb-3">
            <label asp-for="PotSize" class="fw-bold">Pot size</label>
            <small class="text-muted d-block fw-normal">
                The pot size used after repotting (e.g. 9 cm, 4 inch).
            </small>
            <input asp-for="PotSize"
                class="form-control" />
        </div>

        <div class="mb-3">
            <label asp-for="RepotReasonNotes" class="fw-bold">Reason for repotting</label>
            <small class="text-muted d-block fw-normal">
                Optional. For example: medium breaking down, roots overcrowded,
                or moving to a larger pot.
            </small>
            <textarea asp-for="RepotReasonNotes"
                    class="form-control"
                    rows="3"></textarea>
        </div>

        <div class="mb-3">
            <label asp-for="RepottingNotes" class="fw-bold">Additional notes</label>
            <small class="text-muted d-block fw-normal">
                Any other observations during repotting such as root condition or pests.
            </small>
            <textarea asp-for="RepottingNotes"
                    class="form-control"
                    rows="3"></textarea>
        </div>
    }

    <partial name="_FormActions"
            model="@(Model.ReturnUrl 
                    ?? Url.Page("/Plants/Details", new { plantId = Model.PlantId }), 
                    ViewData["Title"]?.ToString() ?? "Save")" />

</form>