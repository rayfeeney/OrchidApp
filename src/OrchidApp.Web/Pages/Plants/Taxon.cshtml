@page "/Plants/Taxon/{taxonId:int}"
@model OrchidApp.Web.Pages.Plants.TaxonModel

@{
    ViewData["Title"] = Model.DisplayName;
}

<h1 class="page-title">
    @Model.DisplayName
    <span class="count">@Model.Plants.Count</span>
</h1>

@if (!Model.Plants.Any())
{
    <div class="empty-state">
        <p>You don’t have any plants of this species/hybrid yet.</p>
    </div>
}
else
{
    <div class="card-list">
        @foreach (var plant in Model.Plants)
        {
            <div class="plant-card-wrapper">

                <!-- Card container (no longer a link) -->
                <div class="plant-card">

                    <div class="plant-main">

                        <!-- Thumbnail tap → Photos -->
                        <a class="plant-thumb-link"
                        asp-page="/Plants/Photos/Index"
                        asp-route-plantId="@plant.PlantId"
                        title="Photos">

                            @if (!string.IsNullOrEmpty(plant.HeroFilePath))
                            {
                                <img src="/@plant.HeroFilePath"
                                    class="plant-thumb"
                                    alt="" />
                            }
                            else
                            {
                                <div class="plant-thumb-placeholder"></div>
                            }

                        </a>

                        <!-- Main area tap → Details -->
                        <a class="plant-text-link"
                        asp-page="/Plants/Details"
                        asp-route-plantId="@plant.PlantId">

                            <div class="plant-text">
                                <div class="plant-tag">@plant.PlantTag</div>

                                @if (!string.IsNullOrWhiteSpace(plant.PlantName))
                                {
                                    <div class="plant-name">@plant.PlantName</div>
                                }

                                <div class="location-line">@plant.LocationName</div>

                                <div class="since">
                                    @if (plant.LocationStartDateTime.HasValue)
                                    {
                                        <text>There since @plant.LocationStartDateTime.Value.ToString("dd/MM/yyyy")</text>
                                    }
                                    else
                                    {
                                        <text>No location yet recorded</text>
                                    }
                                </div>
                            </div>

                        </a>

                    </div>
                </div>

                <!-- Pencil tap → Edit -->
                <a class="plant-edit"
                asp-page="/Plants/Edit/Index"
                asp-route-plantId="@plant.PlantId"
                title="Edit plant">
                    <i class="bi bi-pencil"></i>
                </a>

            </div>
        }
    </div>
}

<div class="mt-4">
    <a asp-page="/Plants/Index"
       class="btn btn-outline-secondary btn-lg w-100">
        ← Back to plants
    </a>
</div>
