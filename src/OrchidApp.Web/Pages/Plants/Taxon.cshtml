@page "/Plants/Taxon/{taxonId:int}"
@model OrchidApp.Web.Pages.Plants.TaxonModel

@{
    ViewData["Title"] = Model.DisplayName;
}

<h1 class="page-title fw-bold @(Model.IsInactive ? "text-muted" : "")">
    @Model.DisplayName

    @if (Model.IsInactive)
    {
        <span class="badge bg-secondary ms-2">Inactive</span>
    }

    <span class="fw-normal fs-6 text-muted">
        (@Model.Plants.Count plant@(Model.Plants.Count == 1 ? "" : "s"))
    </span>
</h1>

<h2 class="h5 fw-bold mb-3">
    Plants recorded under this species / hybrid
</h2>

@if (!Model.Plants.Any())
{
    <div class="empty-state">
        <p class="text-muted">
            You don’t have any plants recorded under this species / hybrid yet.
        </p>
    </div>
}
else
{
    <p class="text-muted small mb-3">
        Tap a plant to view details. Tap the image to see photos. Tap the pencil icon to edit the details of the plant.
    </p>

    <div class="card-list">
        @foreach (var plant in Model.Plants)
        {
            
            var isSelected = Model.SelectedPlantId == plant.PlantId;
            
            <div id="plant-@plant.PlantId" class="plant-card-wrapper">

                <div class="plant-card @(isSelected ? "border border-primary shadow-sm" : "")">
                    <div class="plant-main @(Model.IsInactive ? "text-muted" : "")">

                        <a class="plant-thumb-link"
                           asp-page="/Plants/Photos/Index"
                           asp-route-plantId="@plant.PlantId"
                           asp-route-returnUrl="@(Request.Path + "?selectedPlantId=" + plant.PlantId + "#plant-" + plant.PlantId)"
                           title="Photos">

                            @if (!string.IsNullOrEmpty(plant.HeroFilePath))
                            {
                                <img src="/@plant.HeroFilePath"
                                     class="plant-thumb"
                                     alt="" />
                            }
                            else
                            {
                                <div class="plant-thumb-placeholder d-flex align-items-center justify-content-center">
                                    <i class="bi bi-image text-muted"></i>
                                </div>
                            }

                        </a>

                        <a class="plant-text-link"
                           asp-page="/Plants/Details"
                           asp-route-plantId="@plant.PlantId"
                           asp-route-returnUrl="@(Request.Path + "?selectedPlantId=" + plant.PlantId + "#plant-" + plant.PlantId)">

                            <div class="plant-text">
                                <div class="plant-tag">@plant.PlantTag</div>

                                @if (!string.IsNullOrWhiteSpace(plant.PlantName))
                                {
                                    <div class="plant-name">@plant.PlantName</div>
                                }

                                <div class="since">
                                    @if (plant.LocationStartDateTime.HasValue)
                                    {
                                        <text>
                                            At this location since @plant.LocationStartDateTime.Value.ToString("dd/MM/yyyy")
                                        </text>
                                    }
                                    else
                                    {
                                        <text>No location recorded yet</text>
                                    }
                                </div>
                            </div>

                        </a>

                    </div>
                </div>

                <a class="plant-edit"
                   asp-page="/Plants/Edit/Index"
                   asp-route-plantId="@plant.PlantId"
                   asp-route-returnUrl="@(Request.Path + "?selectedPlantId=" + plant.PlantId + "#plant-" + plant.PlantId)"
                   title="Edit plant">
                    <i class="bi bi-pencil"></i>
                </a>

            </div>
        }
    </div>
}

<partial name="_BackFullWidth"
         model="@(Model.ReturnUrl ?? Url.Page("/Plants/Index"))" />