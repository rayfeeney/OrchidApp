@page "{plantId:int}"
@model OrchidApp.Web.Pages.Plants.Edit.IndexModel

<h1 class="page-title fw-bold">Edit plant</h1>

@if (!string.IsNullOrEmpty(Model.SelectedDisplayName))
{
    <h2 class="h5 fw-bold mb-3">
        @Model.SelectedDisplayName
    </h2>

    <p class="text-muted small mb-3">
        Change genus or species / hybrid first. Then update plant details and save.
    </p>
}

<div asp-validation-summary="All" class="text-danger mb-3"></div>

<!-- ========================= -->
<!-- Genus Change Form -->
<!-- ========================= -->
<form method="post" asp-page-handler="GenusChanged" class="mb-4">
    <input type="hidden" asp-for="PlantId" />

    <div class="mb-3">
        <label asp-for="GenusId" class="fw-bold"></label>
        <small class="text-muted d-block fw-normal">
            Changing genus will reset the species / hybrid list to match that genus. Select the Change genus button to update.
        </small>

        <div class="input-group">
            <select asp-for="GenusId"
                    asp-items="Model.GenusOptions"
                    class="form-select">
            </select>

            <button type="submit" class="btn btn-outline-secondary">
                Change genus
            </button>
        </div>

        <span asp-validation-for="GenusId" class="text-danger"></span>
    </div>
</form>

<!-- ========================= -->
<!-- Species / Hybrid Change Form -->
<!-- ========================= -->
<form method="post" asp-page-handler="TaxonChanged" class="mb-4">
    <input type="hidden" asp-for="PlantId" />
    <input type="hidden" asp-for="GenusId" />

    <div class="mb-3">
        <label asp-for="TaxonId" class="fw-bold"></label>
        <small class="text-muted d-block fw-normal">
            Select the correct species / hybrid for this plant. Select the Change species / hybrid button to update.
        </small>

        <div class="input-group">
            <select asp-for="TaxonId"
                    asp-items="Model.TaxonOptions"
                    class="form-select">
            </select>

            <button type="submit" class="btn btn-outline-secondary">
                Change species / hybrid
            </button>
        </div>

        <span asp-validation-for="TaxonId" class="text-danger"></span>
    </div>
</form>

<!-- ========================= -->
<!-- Main Save Form -->
<!-- ========================= -->
<form method="post" class="mt-3">

    <input type="hidden" asp-for="PlantId" />
    <input type="hidden" asp-for="GenusId" />
    <input type="hidden" asp-for="TaxonId" />

    <div class="mb-3">
        <label asp-for="PlantTag" class="fw-bold"></label>
        <small class="text-muted d-block fw-normal">
            Required. Must be unique within your collection.
        </small>
        <input asp-for="PlantTag" class="form-control" />
        <span asp-validation-for="PlantTag" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="PlantName" class="fw-bold"></label>
        <small class="text-muted d-block fw-normal">
            Optional. A personal name to help you recognise this plant.
        </small>
        <input asp-for="PlantName" class="form-control" />
        <span asp-validation-for="PlantName" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="AcquisitionDate" class="fw-bold"></label>
        <small class="text-muted d-block fw-normal">
            Optional. When you obtained the plant.
        </small>
        <input asp-for="AcquisitionDate"
               type="datetime-local"
               class="form-control"
               asp-format="{0:yyyy-MM-ddTHH:mm}" />
        <span asp-validation-for="AcquisitionDate" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="AcquisitionSource" class="fw-bold"></label>
        <small class="text-muted d-block fw-normal">
            Optional. Where the plant came from (e.g. nursery, friend, swap).
        </small>
        <input asp-for="AcquisitionSource" class="form-control" />
        <span asp-validation-for="AcquisitionSource" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="EndDate" class="fw-bold"></label>
        <small class="text-muted d-block fw-normal">
            Usually left blank. Set only when ending a plant’s lifecycle (for example after a split).
        </small>
        <input asp-for="EndDate"
               type="datetime-local"
               class="form-control"
               asp-format="{0:yyyy-MM-ddTHH:mm}" />
        <span asp-validation-for="EndDate" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="EndNotes" class="fw-bold"></label>
        <small class="text-muted d-block fw-normal">
            Optional. Why the plant ended (for example split, lost, given away).
        </small>
        <textarea asp-for="EndNotes"
                  class="form-control"
                  rows="4"></textarea>
        <span asp-validation-for="EndNotes" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="PlantNotes" class="fw-bold"></label>
        <small class="text-muted d-block fw-normal">
            Optional. Any notes about this plant (care, habits, reminders).
        </small>
        <textarea asp-for="PlantNotes"
                  class="form-control"
                  rows="5"></textarea>
        <span asp-validation-for="PlantNotes" class="text-danger"></span>
    </div>

    <div class="d-flex justify-content-between align-items-stretch mt-4">
        <a asp-page="/Plants/Details"
           asp-route-plantId="@Model.PlantId"
           class="btn btn-outline-secondary btn-lg">
            ← Back to plant
        </a>

        <button type="submit"
                class="btn btn-primary btn-lg">
            Save changes
        </button>
    </div>

</form>