@page "{plantId:int}"
@model OrchidApp.Web.Pages.Plants.Edit.IndexModel

@{
    if (Model.IsEnded)
    {
        ViewData["BodyClass"] = "plant-ended-bg";
    }
}

<div class="plant-page @(Model.IsEnded ? "plant-ended" : "")">
    
<h1 class="page-title fw-bold">Edit plant</h1>

@if (!string.IsNullOrEmpty(Model.SelectedDisplayName))
{
<h2 class="h5 fw-bold mb-3 @((Model.IsInactive || Model.IsEnded) ? "text-muted" : "")">
    @Model.SelectedDisplayName

    @if (Model.IsInactive)
    {
        <span class="badge bg-secondary ms-2">Inactive</span>
    }

    @if (Model.IsEnded)
    {
        <span class="badge bg-dark ms-2">Ended - Read-only</span>
    }
</h2>
}

@if (Model.IsEnded)
{
    <div class="alert alert-secondary mt-3">
        This plant has ended and cannot be edited.
    </div>
}

@if (!Model.IsEnded)
{
    <div class="alert alert-info mt-3">
        <strong>Changing plant taxonomy is a multi-step process.</strong>
        <ul class="mb-0">
            <li>To change genus: select a genus, then choose <strong>Change genus</strong>.</li>
            <li>This will reset the species / hybrid selection to <strong>sp.</strong></li>
            <li>You must then select the correct species / hybrid and choose <strong>Change species / hybrid</strong>.</li>
            <li>Finally, select <strong>Save changes</strong> to confirm all updates.</li>
        </ul>
    </div>
}

<div asp-validation-summary="All" class="text-danger mb-3"></div>

<!-- ========================= -->
<!-- Genus Change Form -->
<!-- ========================= -->
<form method="post" asp-page-handler="GenusChanged" class="mb-4">
    <input type="hidden" asp-for="PlantId" />

    <div class="mb-3">
        <label asp-for="GenusId" class="fw-bold"></label>
        <small class="text-muted d-block fw-normal">
            Selecting a new genus resets the species / hybrid to <strong>sp.</strong>.
            After changing genus, you must choose the correct species / hybrid.
        </small>

            @if (Model.IsEnded)
            {
                <div class="form-control">
                    @Model.GenusName
                </div>
            }
            else
            {
                <div class="input-group">
                    <select asp-for="GenusId"
                            asp-items="Model.GenusOptions"
                            class="form-select">
                    </select>

                    <button type="submit" class="btn btn-outline-secondary">
                        Change genus
                    </button>
                </div>
            }
@*         <div class="input-group">
            <select asp-for="GenusId"
                    asp-items="Model.GenusOptions"
                    class="form-select">
            </select>

            @if (!Model.IsEnded)
            {
                <button type="submit" class="btn btn-outline-secondary">
                    Change genus
                </button>
            }
        </div> *@

        <span asp-validation-for="GenusId" class="text-danger"></span>
    </div>
</form>

<!-- ========================= -->
<!-- Species / Hybrid Change Form -->
<!-- ========================= -->
<form method="post" asp-page-handler="TaxonChanged" class="mb-4">
    <input type="hidden" asp-for="PlantId" />
    <input type="hidden" asp-for="GenusId" />

    <div class="mb-3">
        <label asp-for="TaxonId" class="fw-bold"></label>
        <small class="text-muted d-block fw-normal">
            Select the correct species / hybrid for this plant,
            then choose <strong>Change species / hybrid</strong>.
            Changes are not final until you select <strong>Save changes</strong>.
        </small>

            @if (Model.IsEnded)
            {
                <div class="form-control">
                    @Model.SelectedDisplayName
                </div>
            }
            else
            {
                <div class="input-group">
                    <select asp-for="TaxonId"
                            asp-items="Model.TaxonOptions"
                            class="form-select">
                    </select>

                    <button type="submit" class="btn btn-outline-secondary">
                        Change species / hybrid
                    </button>
                </div>
            }
@*         <div class="input-group">
            <select asp-for="TaxonId"
                    asp-items="Model.TaxonOptions"
                    class="form-select">
            </select>

            @if (!Model.IsEnded)
            {
                <button type="submit" class="btn btn-outline-secondary">
                    Change species / hybrid
                </button>
            }
        </div> *@

        <span asp-validation-for="TaxonId" class="text-danger"></span>
    </div>
</form>

<!-- ========================= -->
<!-- Main Save Form -->
<!-- ========================= -->
<form method="post" class="mt-3">

    <input type="hidden" asp-for="PlantId" />
    <input type="hidden" asp-for="GenusId" />
    <input type="hidden" asp-for="TaxonId" />

    <div class="mb-3">
        <label class="fw-bold">Plant tag</label>
        <small class="text-muted d-block fw-normal">
            System-generated identifier. Cannot be changed.
        </small>
        <div class="form-control">
            <span class="plant-tag">@Model.PlantTag</span>
        </div>
    </div>

    <div class="mb-3">
        <label asp-for="PlantName" class="fw-bold"></label>
        <small class="text-muted d-block fw-normal">
            Optional. A personal name to help you recognise this plant.
        </small>
        @if (Model.IsEnded)
        {
            <input asp-for="PlantName" class="form-control" readonly />
        }
        else
        {
            <input asp-for="PlantName" class="form-control" />
        }
        <span asp-validation-for="PlantName" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="AcquisitionDate" class="fw-bold"></label>
        <small class="text-muted d-block fw-normal">
            Optional. When you obtained the plant.
        </small>
        @if (Model.IsEnded)
        {
            <input asp-for="AcquisitionDate" type="date" class="form-control" readonly />
        }
        else
        {
            <input asp-for="AcquisitionDate" type="date" class="form-control" />
        }
        <span asp-validation-for="AcquisitionDate" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="AcquisitionSource" class="fw-bold"></label>
        <small class="text-muted d-block fw-normal">
            Optional. Where the plant came from (e.g. nursery, friend, swap).
        </small>
        @if (Model.IsEnded)
        {
            <input asp-for="AcquisitionSource" class="form-control" readonly />
        }
        else
        {
            <input asp-for="AcquisitionSource" class="form-control" />
        }
        <span asp-validation-for="AcquisitionSource" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="EndDate" class="fw-bold"></label>
        <small class="text-muted d-block fw-normal">
            Usually left blank. Set only when ending a plant’s lifecycle (for example if it dies or is given away).
        </small>
        @if (Model.IsEnded)
        {
            <input asp-for="EndDate" type="date" class="form-control" readonly />
        }
        else
        {
            <input asp-for="EndDate" type="date" class="form-control" />
        }        
        @* <input asp-for="EndDate" type="date" class="form-control" /> *@
        <span asp-validation-for="EndDate" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="EndNotes" class="fw-bold"></label>
        <small class="text-muted d-block fw-normal">
            Optional. Why the plant ended (for example lost, given away).
        </small>
        @if (Model.IsEnded)
        {
            <input asp-for="EndNotes" class="form-control" readonly />
        }
        else
        {
            <input asp-for="EndNotes" class="form-control" />
        }
        <span asp-validation-for="EndNotes" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="PlantNotes" class="fw-bold"></label>
        <small class="text-muted d-block fw-normal">
            Optional. Any notes about this plant (care, habits, reminders).
        </small>
        @if (Model.IsEnded)
        {
            <input asp-for="PlantNotes" class="form-control" readonly />
        }
        else
        {
            <input asp-for="PlantNotes" class="form-control" />
        }
        <span asp-validation-for="PlantNotes" class="text-danger"></span>
    </div>

    <p class="text-muted">
        All taxonomy changes are only final after selecting <strong>Save changes</strong>.
    </p>

    <div class="d-flex justify-content-between align-items-stretch mt-4">
        <a asp-page="/Plants/Details"
           asp-route-plantId="@Model.PlantId"
           class="btn btn-outline-secondary btn-lg">
            ← Back to plant
        </a>

        @if (!Model.IsEnded)
        {
            <button type="submit"
                    class="btn btn-primary btn-lg">
                Save changes
            </button>
        }
    </div>

</form>
</div>