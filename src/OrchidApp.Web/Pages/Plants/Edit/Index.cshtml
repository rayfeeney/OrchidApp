@page "{plantId:int}"
@model OrchidApp.Web.Pages.Plants.Edit.IndexModel

<h1 class="page-title">Edit plant</h1>

@if (!ViewData.ModelState.IsValid)
{
    <div class="text-danger mb-3">
        @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
        {
            <div>@err.ErrorMessage</div>
        }
    </div>
}

<form method="post" class="mt-3">

    <input type="hidden" asp-for="PlantId" />

    <div class="mb-3">
        <label asp-for="TaxonId" class="form-label">Species / hybrid</label>
        <select asp-for="TaxonId"
                asp-items="Model.TaxonOptions"
                class="form-select"></select>
    </div>

    <div class="mb-3">
        <label asp-for="PlantTag" class="form-label"></label>
        <input asp-for="PlantTag" class="form-control" />
        <span asp-validation-for="PlantTag" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="PlantName" class="form-label"></label>
        <input asp-for="PlantName" class="form-control" />
        <span asp-validation-for="PlantName" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="AcquisitionDate" class="form-label"></label>
        <input asp-for="AcquisitionDate"
               type="datetime-local"
               class="form-control" />
        <span asp-validation-for="AcquisitionDate" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="AcquisitionSource" class="form-label"></label>
        <input asp-for="AcquisitionSource" class="form-control" />
        <span asp-validation-for="AcquisitionSource" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="EndDate" class="form-label"></label>
        <input asp-for="EndDate"
               type="datetime-local"
               class="form-control" />
        <span asp-validation-for="EndDate" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="EndNotes" class="form-label"></label>
        <textarea asp-for="EndNotes"
                  class="form-control"
                  rows="4"></textarea>
        <span asp-validation-for="EndNotes" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="PlantNotes" class="form-label"></label>
        <textarea asp-for="PlantNotes"
                  class="form-control"
                  rows="5"></textarea>
        <span asp-validation-for="PlantNotes" class="text-danger"></span>
    </div>

    <partial name="_FormActions"
             model="@(Model.ReturnUrl ?? Url.Page("/Plants/Details", new { plantId = Model.PlantId }), "Save")" />

</form>