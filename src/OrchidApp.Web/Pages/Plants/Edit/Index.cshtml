@page "{plantId:int}"
@model OrchidApp.Web.Pages.Plants.Edit.IndexModel

<h1 class="page-title">Edit plant</h1>

@if (!string.IsNullOrEmpty(Model.SelectedDisplayName))
{
    <h5 class="text-muted mb-3">@Model.SelectedDisplayName</h5>
}

@if (!ViewData.ModelState.IsValid)
{
    <div class="text-danger mb-3">
        @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
        {
            <div>@err.ErrorMessage</div>
        }
    </div>
}

<!-- ========================= -->
<!-- Genus Change Form -->
<!-- ========================= -->
<form method="post" asp-page-handler="GenusChanged" class="mb-3">
    <input type="hidden" asp-for="PlantId" />

    <label class="form-label">Genus</label>
    <div class="input-group">
        <select asp-for="GenusId"
                asp-items="Model.GenusOptions"
                class="form-select">
        </select>
        <button type="submit"
                class="btn btn-outline-secondary">
            Change
        </button>
    </div>
</form>

<!-- ========================= -->
<!-- Taxon Change Form -->
<!-- ========================= -->
<form method="post" asp-page-handler="TaxonChanged" class="mb-4">
    <input type="hidden" asp-for="PlantId" />
    <input type="hidden" asp-for="GenusId" />

    <label class="form-label">Species / hybrid</label>
    <div class="input-group">
        <select asp-for="TaxonId"
                asp-items="Model.TaxonOptions"
                class="form-select">
        </select>
        <button type="submit"
                class="btn btn-outline-secondary">
            Change
        </button>
    </div>
</form>

<!-- ========================= -->
<!-- Main Save Form -->
<!-- ========================= -->
<form method="post" class="mt-3">

    <input type="hidden" asp-for="PlantId" />
    <input type="hidden" asp-for="GenusId" />
    <input type="hidden" asp-for="TaxonId" />

    <div class="mb-3">
        <label class="form-label">Plant tag</label>
        <input asp-for="PlantTag" class="form-control" />
        <span asp-validation-for="PlantTag" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label class="form-label">Plant name</label>
        <input asp-for="PlantName" class="form-control" />
        <span asp-validation-for="PlantName" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label class="form-label">Acquired on</label>
        <input asp-for="AcquisitionDate"
               type="datetime-local"
               class="form-control"
               value="@Model.AcquisitionDate.ToString("yyyy-MM-ddTHH:mm")" />
        <span asp-validation-for="AcquisitionDate" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label class="form-label">Acquired from</label>
        <input asp-for="AcquisitionSource" class="form-control" />
        <span asp-validation-for="AcquisitionSource" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label class="form-label">End date</label>
        <input asp-for="EndDate"
               type="datetime-local"
               class="form-control"
               value="@(Model.EndDate?.ToString("yyyy-MM-ddTHH:mm"))" />
        <span asp-validation-for="EndDate" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label class="form-label">End notes</label>
        <textarea asp-for="EndNotes"
                  class="form-control"
                  rows="4"></textarea>
        <span asp-validation-for="EndNotes" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label class="form-label">Plant notes</label>
        <textarea asp-for="PlantNotes"
                  class="form-control"
                  rows="5"></textarea>
        <span asp-validation-for="PlantNotes" class="text-danger"></span>
    </div>

    <div class="d-flex justify-content-between align-items-stretch mt-4">
        <a href="@Url.Page("/Plants/Taxon", new { genusId = Model.GenusId, taxonId = Model.TaxonId })"
           class="btn btn-outline-secondary btn-lg">
            ← Back
        </a>

        <button type="submit"
                class="btn btn-primary btn-lg">
            Save
        </button>
    </div>

</form>