@page "{plantId:int}"
@model OrchidApp.Web.Pages.Plants.Photos.IndexModel

<h1 class="page-title fw-bold">Photos</h1>

<h2 class="h5 fw-bold mb-3">
    @Model.PlantDisplayName
    @if (!string.IsNullOrWhiteSpace(Model.PlantTag))
    {
        <span class="fw-normal text-muted"> (@Model.PlantTag)</span>
    }
</h2>

<div class="card mt-3 mb-3">
    <div class="card-body">
        <dl class="row mb-0">

            <dt class="col-sm-3 fw-bold">Tag</dt>
            <dd class="col-sm-9">
                @(string.IsNullOrWhiteSpace(Model.PlantTag) ? "—" : Model.PlantTag)
            </dd>

            <dt class="col-sm-3 fw-bold">Location</dt>
            <dd class="col-sm-9">
                @(string.IsNullOrWhiteSpace(Model.LocationName) ? "—" : Model.LocationName)
            </dd>

        </dl>
    </div>
</div>

@if (Model.FocusPhoto != null)
{
    <div class="text-center">

        <img src="~/@Model.FocusPhoto.FilePath"
             class="img-fluid rounded shadow"
             style="max-height:60vh;" />

        @if (!Model.FocusPhoto.IsHero)
        {
            <form method="post"
                  asp-page-handler="SetHero"
                  class="mt-3">

                <input type="hidden" name="plantId" value="@Model.PlantId" />
                <input type="hidden" name="photoId" value="@Model.FocusPhoto.PlantPhotoId" />

                <button type="submit"
                        class="btn btn-outline-primary btn-lg">
                    Set as main image
                </button>
            </form>
        }
        else
        {
            <div class="mt-3">
                <span class="badge bg-success">
                    Main image
                </span>
            </div>
        }

    </div>
    
}
else
{
    <div class="alert alert-info mt-3 text-center">
        No photos have been added yet.
        Add a photo from the plant’s History using “Add observation”.
    </div>
}

@if (Model.Photos.Count > 0)
{
<p class="text-muted small mt-3 text-center">
    Tap a thumbnail below to view a different photo.
</p>

    <div class="d-flex justify-content-between mt-3 mb-3">

        @if (Model.PreviousPhotoId.HasValue)
        {
            <a asp-route-plantId="@Model.PlantId"
               asp-route-focusPhotoId="@Model.PreviousPhotoId"
               class="btn btn-outline-primary btn-lg">
                ◀ Previous photo
            </a>
        }
        else
        {
            <span></span>
        }

        @if (Model.NextPhotoId.HasValue)
        {
            <a asp-route-plantId="@Model.PlantId"
               asp-route-focusPhotoId="@Model.NextPhotoId"
               class="btn btn-outline-primary btn-lg">
                Next photo ▶
            </a>
        }

    </div>
}

@if (Model.Photos.Count > 1)
{
    <div class="mt-4">
        <div class="d-flex overflow-auto gap-2 pb-2">

            @foreach (var photo in Model.Photos)
            {
                <a asp-route-plantId="@Model.PlantId"
                   asp-route-focusPhotoId="@photo.PlantPhotoId"
                   class="flex-shrink-0">

                    <img src="~/@photo.FilePath"
                         class="rounded border @(photo.PlantPhotoId == Model.FocusPhoto?.PlantPhotoId ? "border-primary border-3" : "")"
                         style="height:80px; width:80px; object-fit:cover;" />
                </a>
            }

        </div>
    </div>
}

<partial name="_BackFullWidth"
         model="@(Model.ReturnUrl ?? Url.Page("/Plants/Details", new { plantId = Model.PlantId }))" />