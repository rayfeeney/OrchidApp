@page "{plantTag?}"
@model OrchidApp.Web.Pages.Plants.Tag.IndexModel

<h1 class="page-title fw-bold">Find plant</h1>

<h2 class="h5 fw-bold mb-3">Enter plant tag</h2>

<form method="get">
    <div class="mb-3">
        <label asp-for="PlantTag" class="fw-bold">Plant tag</label>
        <input asp-for="PlantTag" class="form-control" />
        <span asp-validation-for="PlantTag" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary btn-lg w-100">
        Find plant
    </button>

    <div class="mt-3">
        <a asp-page="/Plants/Index" class="btn btn-primary btn-lg w-100">
            View all plants
        </a>
    </div>
</form>

<div asp-validation-summary="All" class="text-danger mt-3"></div>