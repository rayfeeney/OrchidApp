{
  "MediaIngestion": {
  "MaxImageDimension": 3072,
  "JpegQuality": 90,
  "StripGpsMetadata": true
},
  "Storage": {
    "UploadRoot": "/opt/orchidapp/uploads"
  },
  "Logging": {
  "LogLevel": {
    "Default": "Information",
    "Microsoft": "Warning",
    "Microsoft.EntityFrameworkCore": "Error",
    "NetVips": "Error",
    "OrchidApp.Web.Services.PhotoPipeline": "Information"
  }
},
  "AllowedHosts": "*"
}
